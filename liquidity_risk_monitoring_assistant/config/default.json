{
  "agent_handoffs": {},
  "alerts": {
    "advice_interval_ticks": 5,
    "important_move_pct": 1.5,
    "slack_channel": "#claw",
    "slack_cooldown_ticks_per_symbol": 20,
    "slack_digest_every_ticks": 100,
    "slack_enabled": true,
    "slack_min_confidence": 0.65,
    "slack_policy_mode": "important_only"
  },
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills"
  ],
  "human_control": {
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "notice_only",
    "notice_event": "human_notice",
    "reason": "The workflow may surface notable findings for review but does not apply irreversible actions by itself.",
    "requires_ack": false
  },
  "identity": {
    "blueprint_id": "liquidity_risk_monitoring_assistant",
    "name": "Liquidity Risk Monitoring Assistant"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {}
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
