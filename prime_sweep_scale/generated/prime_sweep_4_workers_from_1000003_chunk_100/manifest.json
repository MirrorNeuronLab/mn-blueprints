{
  "manifest_version": "1.0",
  "graph_id": "prime_sweep_4_workers",
  "job_name": "prime-sweep-4-workers",
  "entrypoints": [
    "dispatcher"
  ],
  "initial_inputs": {
    "dispatcher": [
      {
        "benchmark": "prime_sweep",
        "worker_count": 4,
        "requested_workers": 4,
        "chunk_size": 100,
        "range_start": 1000003,
        "range_end": 1000402
      }
    ]
  },
  "nodes": [
    {
      "node_id": "dispatcher",
      "agent_type": "router",
      "type": "map",
      "role": "root_coordinator",
      "config": {
        "emit_type": "prime_chunk_request"
      }
    },
    {
      "node_id": "collector",
      "agent_type": "aggregator",
      "type": "reduce",
      "config": {
        "complete_after": 4,
        "output_message_type": "prime_chunk_collection"
      }
    },
    {
      "node_id": "summarizer",
      "agent_type": "executor",
      "type": "reduce",
      "config": {
        "name_prefix": "prime-summary",
        "upload_path": "summary_worker",
        "upload_as": "summary_worker",
        "workdir": "/sandbox/job/summary_worker",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "command": [
          "python3",
          "scripts/summarize_prime_sweep.py"
        ],
        "output_message_type": null
      }
    },
    {
      "node_id": "prime_worker_0001",
      "agent_type": "executor",
      "type": "map",
      "config": {
        "name_prefix": "prime-worker-0001",
        "from": "base",
        "upload_path": "prime_worker",
        "upload_as": "prime_worker",
        "workdir": "/sandbox/job/prime_worker",
        "command": [
          "python3",
          "scripts/check_prime_range.py",
          "prime_worker_0001",
          "1000003",
          "1000102"
        ],
        "pool": "default",
        "pool_slots": 1,
        "output_message_type": "prime_chunk_result",
        "startup_delay_ms": 0,
        "max_attempts": 4,
        "retry_backoff_ms": 500,
        "no_keep": true,
        "no_auto_providers": true,
        "tty": false
      }
    },
    {
      "node_id": "prime_worker_0002",
      "agent_type": "executor",
