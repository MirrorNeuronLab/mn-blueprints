{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_live_telemetry_stream_pipeline",
    "name": "Live Telemetry Stream Pipeline"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {}
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters",
      "telemetry",
      "peak_detection",
      "manifest_config_bindings"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Stream processor and summarizer.",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "IoT telemetry, application logs, market data, operational sensors.",
    "problem_solved": "Streaming systems require backpressure-aware routing, stateful workers, and outputs that remain interpretable as events arrive.",
    "target_users": "Developers building event-stream workflows and runtime observability paths."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Signal summary and stream result artifacts.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Live telemetry stream."
  },
  "standard_version": "1.0",
  "telemetry": {
    "chunk_size": 6,
    "interval_ms": 1000,
    "baseline": 24,
    "jitter": 4,
    "peak_height": 55,
    "peak_every": 20,
    "device_id": "sensor-alpha",
    "content_encoding": "gzip"
  },
  "peak_detection": {
    "warmup_points": 5,
    "window_size": 8,
    "spike_multiplier": 2.4,
    "min_spike_delta": 20.0
  },
  "manifest_config_bindings": [
    {
      "config_path": "telemetry.chunk_size",
      "manifest_path": "nodes.telemetry_source.config.chunk_size"
    },
    {
      "config_path": "telemetry.interval_ms",
      "manifest_path": "nodes.telemetry_source.config.interval_ms"
    },
    {
      "config_path": "telemetry.baseline",
      "manifest_path": "nodes.telemetry_source.config.baseline"
    },
    {
      "config_path": "telemetry.jitter",
      "manifest_path": "nodes.telemetry_source.config.jitter"
    },
    {
      "config_path": "telemetry.peak_height",
      "manifest_path": "nodes.telemetry_source.config.peak_height"
    },
    {
      "config_path": "telemetry.peak_every",
      "manifest_path": "nodes.telemetry_source.config.peak_every"
    },
    {
      "config_path": "telemetry.device_id",
      "manifest_path": "nodes.telemetry_source.config.device_id"
    },
    {
      "config_path": "telemetry.content_encoding",
      "manifest_path": "nodes.telemetry_source.config.content_encoding"
    },
    {
      "config_path": "peak_detection.warmup_points",
      "manifest_path": "nodes.peak_detector.config.environment.WARMUP_POINTS",
      "stringify": true
    },
    {
      "config_path": "peak_detection.window_size",
      "manifest_path": "nodes.peak_detector.config.environment.WINDOW_SIZE",
      "stringify": true
    },
    {
      "config_path": "peak_detection.spike_multiplier",
      "manifest_path": "nodes.peak_detector.config.environment.SPIKE_MULTIPLIER",
      "stringify": true
    },
    {
      "config_path": "peak_detection.min_spike_delta",
      "manifest_path": "nodes.peak_detector.config.environment.MIN_SPIKE_DELTA",
      "stringify": true
    }
  ]
}
