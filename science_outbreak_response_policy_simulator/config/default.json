{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "science_outbreak_response_policy_simulator",
    "name": "Outbreak Response Policy Simulator"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "population": 50000,
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Public-health intervention advisor",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe infections and hospital load",
      "choose interventions",
      "write an intervention plan"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "science",
    "customizable_for": "Campus health, local agencies, hospital systems, workplace safety.",
    "problem_solved": "Outbreak response depends on time-varying spread and healthcare load; static dashboards cannot test policy consequences before action.",
    "target_users": "Public-health planners, epidemiology teams, campus operations, and policy analysts."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Public-health intervention plan with state trajectory.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "vaccination_push",
      "reduce_mobility",
      "increase_testing"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "infected_people",
      "vaccination_pct",
      "mobility_index",
      "hospital_load_pct"
    ],
    "objective": "minimize",
    "primary_metric": "infected_people",
    "risk_metric": "hospital_load_pct",
    "seed_field": "seed",
    "type": "Disease spread and intervention simulation."
  },
  "standard_version": "1.0"
}
