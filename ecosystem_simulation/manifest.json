{
  "apiVersion": "mn.workflow/v1",
  "kind": "Workflow",
  "id": "ecosystem_simulation",
  "name": "Ecosystem Simulation",
  "version": "1.0.0",
  "manifest_version": "1.0",
  "description": "Use this blueprint to explore ecosystem interventions across regions and compare population effects before making policy or field decisions.",
  "graph_id": "ecosystem_simulation_v1",
  "job_name": "ecosystem-simulation",
  "type": "service",
  "contract": {
    "summary": "Use this blueprint to explore ecosystem interventions across regions and compare population effects before making policy or field decisions.",
    "users": [
      "Ecologists, conservation analysts, simulation researchers, and education teams."
    ],
    "inputs": {
      "ecosystem": {
        "type": "dict",
        "required": true,
        "description": "Domain input value for ecosystem.",
        "example": {
          "duration_seconds": 300,
          "food_regen_per_tick": 72.0,
          "local_top_k": 20,
          "max_food": 420.0,
          "max_region_population": 220,
          "migration_rate": 0.035,
          "mutation_rate": 0.05,
          "region_count": 16,
          "seed": 517498978,
          "tick_delay_ms": 1000,
          "tick_seconds": 5,
          "total_animals": 2000
        },
        "privacy": "internal"
      },
      "scenario": {
        "type": "str",
        "required": true,
        "description": "Domain input value for scenario.",
        "example": "ecosystem_competition",
        "privacy": "internal"
      }
    },
    "input_adapters": {
      "default": "mock",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "resolved_artifact": "inputs.json"
    },
    "outputs": {
      "profile": "standard_run_store",
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "type": "final_artifact",
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ]
      },
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        }
      ]
    },
    "events": {
      "stream": "events.jsonl",
      "human_stream": "human.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_worker_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "typed event objects with payload",
        "region_bootstrap",
        "region_summary",
        "simulation_start",
        "region_collection"
      ]
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": false,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "privacy": {
      "default_classification": "internal",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    }
  },
  "flow": {
    "entrypoint": "load_inputs",
    "state": {
      "resolved_inputs": {},
      "workflow_result": {},
      "final_artifact": {}
    },
    "steps": [
      {
        "id": "load_inputs",
        "kind": "stage",
        "label": "Load Inputs",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "action": "load_inputs",
        "in": {},
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs",
        "emits": "inputs_loaded",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "run_workflow",
        "kind": "stage",
        "label": "Run Workflow",
        "goal": "Ecological systems change through local interactions, migration, resources, and mutation; interventions need scenario testing before field action.",
        "action": "run_blueprint_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow",
        "emits": "workflow_result_ready",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "control": {
          "required": true,
          "timeout_seconds": null,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "write_final_artifact",
        "kind": "stage",
        "label": "Write Final Artifact",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "action": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact",
        "emits": "final_artifact_written",
        "on": {
          "final_artifact_written": "completed"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      }
    ],
    "graph": {
      "schema": "mn.workflow.problem_graph/v1",
      "mode": "static_dag",
      "source": "load_inputs",
      "sink": "write_final_artifact",
      "execution": {
        "strategy": "serial"
      },
      "dynamic": {
        "enabled": false,
        "patch_events": [],
        "apply_at": "between_steps"
      },
      "edges": [
        {
          "id": "load_inputs_to_run_workflow",
          "from": "load_inputs",
          "to": "run_workflow",
          "event": "inputs_loaded",
          "required": true,
          "accepts": [
            "done"
          ]
        },
        {
          "id": "run_workflow_to_write_final_artifact",
          "from": "run_workflow",
          "to": "write_final_artifact",
          "event": "workflow_result_ready",
          "required": true,
          "accepts": [
            "done"
          ]
        }
      ]
    },
    "policy": {
      "safety": {
        "default": "allow",
        "blocked_actions": [],
        "rules": []
      },
      "human": {
        "enabled": true,
        "mode": "notice_only",
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "reject",
        "timeout_seconds": null,
        "events": {
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout",
          "decision": "human_decision_applied"
        }
      },
      "failure": {
        "default": "fail_closed"
      }
    },
    "observers": []
  },
  "runtime": {
    "store": {
      "type": "local_run_store",
      "path": "./runs/${run_id}",
      "artifacts": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "worker_defaults": {
      "uses": "mn-agents.data_python_executor@1.0.0",
      "runner": "MirrorNeuron.Runner.HostLocal",
      "pool": "default",
      "pool_slots": 1,
      "workdir": "/sandbox/job/workflow"
    },
    "bindings": {
