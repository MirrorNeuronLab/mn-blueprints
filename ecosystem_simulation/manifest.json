  "name": "Ecosystem Simulation",
  "nodes": [
    {
      "node_id": "ingress",
      "uses": "mn-agents.control_router@1.0.0",
      "with": {
        "emit_type": "simulation_start",
        "node_type": "map",
        "role": "root_coordinator"
      }
    },
    {
      "node_id": "world",
      "uses": "mn-agents.data_module@1.0.0",
      "with": {
        "duration_seconds": 300,
        "food_regen_per_tick": 72.0,
        "local_top_k": 20,
        "max_food": 420.0,
        "max_region_population": 220,
        "migration_rate": 0.035,
        "module": "MirrorNeuron.Examples.EcosystemSimulation.WorldAgent",
        "module_source": "beam_modules/world_agent.ex",
        "mutation_rate": 0.05,
        "node_type": "reduce",
        "region_count": 16,
        "role": "world",
        "seed": 517498978,
        "tick_delay_ms": 1000,
        "tick_seconds": 5,
        "total_animals": 2000
      }
    },
    {
      "node_id": "collector",
      "uses": "mn-agents.control_join@1.0.0",
      "with": {
        "complete_after": 16,
        "complete_on_message": true,
        "node_type": "reduce",
        "output_message_type": "region_collection"
      }
    },
    {
      "node_id": "summarizer",
      "uses": "mn-agents.data_module@1.0.0",
      "with": {
        "module": "MirrorNeuron.Examples.EcosystemSimulation.LeaderboardAgent",
        "module_source": "beam_modules/leaderboard_agent.ex",
        "node_type": "reduce"
