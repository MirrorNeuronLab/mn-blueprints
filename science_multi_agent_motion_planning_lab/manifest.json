    "llm": {},
    "llm_agent_role": "World simulator and visualization summarizer.",
    "name": "Multi Agent Motion Planning Lab",
    "output": "Simulation summary and visual artifacts.",
    "output_contract": {
      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "Multi-agent coordination depends on changing positions, goals, and collisions; users need visual traces, not only scalar metrics.",
    "quick_test": {
      "description": "Use generated quick-test bundles when available; fixed blueprints use local dry-run/mock provider environment variables and deterministic sample inputs.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "multi-agent simulation",
      "visualization",
      "shared-world state",
      "summary generation"
    ],
    "simulation_type": "Multi-agent particle environment.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "target_user": "Robotics researchers, simulation developers, and multi-agent systems educators."
  },
  "name": "Multi Agent Motion Planning Lab",
  "nodes": [
    {
      "agent_type": "router",
      "config": {
        "emit_type": "simulation_start"
      },
      "node_id": "ingress",
      "role": "root_coordinator",
      "type": "map",
      "uses": "mn-agents.control_router@1.0.0",
      "with": {
        "emit_type": "simulation_start",
        "node_type": "map",
        "role": "root_coordinator"
      }
    },
    {
      "agent_type": "aggregator",
      "config": {
        "complete_after": 1,
        "output_message_type": "shared_world_collection"
      },
      "node_id": "collector",
      "type": "reduce",
      "uses": "mn-agents.control_join@1.0.0",
      "with": {
        "complete_after": 1,
        "complete_on_message": true,
        "node_type": "reduce",
        "output_message_type": "shared_world_collection"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/build_shared_world_visualization.py"
        ],
        "name_prefix": "mpe-crowd-visualizer",
        "output_message_type": null,
        "pass_env": [
          "PATH"
        ],
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "tty": false,
        "upload_as": "visualizer",
        "upload_path": "visualizer",
        "workdir": "/sandbox/job/visualizer"
      },
      "node_id": "visualizer",
      "type": "reduce",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "name_prefix": "mpe-crowd-visualizer",
        "node_type": "reduce",
        "output_message_type": null,
        "pass_env": [
          "PATH"
        ],
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/build_shared_world_visualization.py",
        "upload_path": "visualizer"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/run_shared_world.py"
        ],
        "environment": {
          "MAX_CYCLES": "60",
          "NUM_ADVERSARIES": "75",
          "NUM_GOOD": "25",
          "NUM_OBSTACLES": "8",
          "POLICY_MODE": "swarm",
          "SIMULATION_SEED": "4200"
        },
        "name_prefix": "mpe-crowd-world",
        "output_message_type": "shared_world_result",
        "pass_env": [
          "PATH",
          "MN_RUN_ID",
          "MN_RUNS_ROOT",
          "MN_NO_RUN_STORE",
          "MN_DISABLE_RUN_STORE",
          "MN_BLUEPRINT_CONFIG_PATH",
          "MN_BLUEPRINT_CONFIG_JSON"
        ],
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "tty": false,
        "upload_as": "world_worker",
        "upload_path": "world_worker",
        "workdir": "/sandbox/job/world_worker"
      },
      "node_id": "shared_world",
      "role": "world",
      "type": "map",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "environment": {
          "MAX_CYCLES": "60",
          "NUM_ADVERSARIES": "75",
          "NUM_GOOD": "25",
          "NUM_OBSTACLES": "8",
          "POLICY_MODE": "swarm",
          "SIMULATION_SEED": "4200"
        },
        "name_prefix": "mpe-crowd-world",
        "node_type": "map",
        "output_message_type": "shared_world_result",
        "pass_env": [
          "PATH",
          "MN_RUN_ID",
          "MN_RUNS_ROOT",
          "MN_NO_RUN_STORE",
          "MN_DISABLE_RUN_STORE",
          "MN_BLUEPRINT_CONFIG_PATH",
          "MN_BLUEPRINT_CONFIG_JSON"
        ],
        "role": "world",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/run_shared_world.py",
        "upload_path": "world_worker"
      }
    }
  ],
  "policies": {
    "recovery_mode": "cluster_recover"
  },
  "requiredContextEngine": false
}
