{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "business_facility_safety_video_guardian",
    "name": "Facility Safety Video Guardian"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {}
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters",
      "video_source",
      "vl_model",
      "safety_alerts",
      "manifest_config_bindings"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Safety observation and escalation agent.",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "business",
    "customizable_for": "Door monitoring, restricted-area alerts, retail safety, warehouse operations.",
    "problem_solved": "Video monitoring is continuous, noisy, and operationally sensitive; teams need stateful alerts, cooldowns, and explainable observations rather than raw frames.",
    "target_users": "Facilities, security, safety operations, and property management teams."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Detection events, alert decisions, and notification payloads.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Video stream sampling with alert state."
  },
  "standard_version": "1.0",
  "video_source": {
    "uri": "samples/door-demo.mp4",
    "camera_id": "front-door",
    "interval_ms": 5000,
    "frame_sample_seconds": 5.0,
    "frame_jpeg_max_width": 896
  },
  "vl_model": {
    "base_url": "http://192.168.4.173:11434",
    "model": "nemotron3:33b"
  },
  "safety_alerts": {
    "confidence_threshold": 0.65,
    "alert_cooldown_seconds": 60,
    "slack_enabled": "true",
    "slack_channel": "#safety",
    "slack_message_prefix": "Door camera safety alert"
  },
  "manifest_config_bindings": [
    {
      "config_path": "video_source.camera_id",
      "manifest_path": "nodes.door_camera_tick_source.config.camera_id"
    },
    {
      "config_path": "video_source.interval_ms",
      "manifest_path": "nodes.door_camera_tick_source.config.interval_ms"
    },
    {
      "config_path": "video_source.uri",
      "manifest_path": "nodes.person_detector.config.environment.VIDEO_SOURCE_URI",
      "stringify": true
    },
    {
      "config_path": "video_source.frame_sample_seconds",
      "manifest_path": "nodes.person_detector.config.environment.FRAME_SAMPLE_SECONDS",
      "stringify": true
    },
    {
      "config_path": "video_source.frame_jpeg_max_width",
      "manifest_path": "nodes.person_detector.config.environment.FRAME_JPEG_MAX_WIDTH",
      "stringify": true
    },
    {
      "config_path": "vl_model.base_url",
      "manifest_path": "initial_inputs.ingress.0.ollama_base_url"
    },
    {
      "config_path": "vl_model.base_url",
      "manifest_path": "nodes.person_detector.config.environment.OLLAMA_BASE_URL",
      "stringify": true
    },
    {
      "config_path": "vl_model.base_url",
      "manifest_path": "nodes.person_detector.config.environment.VL_MODEL_BASE_URL",
      "stringify": true
    },
    {
      "config_path": "vl_model.model",
      "manifest_path": "initial_inputs.ingress.0.ollama_model"
    },
    {
      "config_path": "vl_model.model",
      "manifest_path": "nodes.person_detector.config.environment.OLLAMA_MODEL",
      "stringify": true
    },
    {
      "config_path": "vl_model.model",
      "manifest_path": "nodes.person_detector.config.environment.VL_MODEL_NAME",
      "stringify": true
    },
    {
      "config_path": "safety_alerts.confidence_threshold",
      "manifest_path": "nodes.person_detector.config.environment.PERSON_DETECTION_CONFIDENCE_THRESHOLD",
      "stringify": true
    },
    {
      "config_path": "safety_alerts.alert_cooldown_seconds",
      "manifest_path": "nodes.person_detector.config.environment.PERSON_ALERT_COOLDOWN_SECONDS",
      "stringify": true
    },
    {
      "config_path": "safety_alerts.slack_enabled",
      "manifest_path": "nodes.person_detector.config.environment.SLACK_ALERT_ENABLED",
      "stringify": true
    },
    {
      "config_path": "safety_alerts.slack_channel",
      "manifest_path": "nodes.person_detector.config.environment.SLACK_DEFAULT_CHANNEL",
      "stringify": true
    },
    {
      "config_path": "safety_alerts.slack_message_prefix",
      "manifest_path": "nodes.person_detector.config.environment.SLACK_MESSAGE_PREFIX",
      "stringify": true
    }
  ]
}
