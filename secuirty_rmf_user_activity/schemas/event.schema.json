{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorneuron.local/schemas/security-user-activity-event.schema.json",
  "title": "Security User Activity Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "user_id"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "source_ip": {
      "type": "string"
    },
    "geo": {
      "type": "object",
      "properties": {
        "country": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "city": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "device_id": {
      "type": "string"
    },
    "user_agent": {
      "type": "string"
    },
    "resource": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

