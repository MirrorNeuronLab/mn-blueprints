          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1"
      },
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "output_skills": [],
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "Multi-agent coordination depends on changing positions, goals, and collisions; users need visual traces, not only scalar metrics.",
    "quick_test": {
      "description": "Use generated quick-test bundles when available; fixed blueprints use local dry-run/mock provider environment variables and deterministic sample inputs.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "multi-agent simulation",
      "visualization",
      "shared-world state",
      "summary generation",
      "transparent run status",
      "human control policy",
      "artifact records",
      "run-store observability dashboard",
      "Membrane context memory optimization"
    ],
    "simulation_type": "Multi-agent particle environment.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0",
      "workflow_api_version": "mn.workflow/v1",
      "workflow_model": "contract -> workflow -> agents/runtime"
    },
    "standard_version": "1.0",
    "status_contract": {
      "heartbeat_event": "blueprint_status",
      "heartbeat_required": false,
      "phases": [
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "loading_inputs",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "running_worker",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "waiting_for_human",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "writing_artifacts",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "completed",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        }
      ],
      "schema_version": "mn.blueprint.status_contract.v1",
      "source": "run_store",
      "status_event": "blueprint_status"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "target_user": "Robotics researchers, simulation developers, and multi-agent systems educators.",
    "web_ui": {
      "adapter": "gradio",
      "data_source": "local_run_store",
      "description": "Shared blueprint support dashboard rendered from local run-store events and artifacts.",
      "enabled": true,
      "kind": "output",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ],
      "registration": {
        "api": [
          "main"
        ],
        "module": "mn_blueprint_support.gradio_dashboard",
        "package": "mirrorneuron-blueprint-support-skill[webui]",
        "service": {
          "lifecycle": "runtime_managed",
          "meta": {
            "adapter": "gradio",
            "blueprint_id": "robot_motion_planning_assistant",
            "run_id": "${run_id}"
          },
          "provider": "mirror_neuron",
          "registered_by": "launch_prepare_web_ui",
          "service_name": "blueprint-web-ui",
          "tags": [
            "web_ui",
            "blueprint",
            "robot_motion_planning_assistant",
            "gradio"
          ]
        },
        "writes": "ui.json and web_ui.json"
      },
      "server": "blueprint_support",
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    }
  },
  "name": "Robot Motion Planning Assistant",
  "policies": {
    "recovery_mode": "cluster_recover"
  },
  "requiredContextEngine": false,
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "runtime": {
    "bindings": {
      "load_inputs": {
        "risk": "low",
        "side_effect": "read",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "input_adapter",
            "model": "ollama/nemotron3:33b",
            "role": "Resolve mock, JSON, file, or env_json inputs",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      },
      "run_workflow": {
        "risk": "medium",
        "routes": [
          {
            "edge_id": "ingress_to_world",
            "from_node": "ingress",
            "message_type": "simulation_start",
            "to_node": "shared_world_simulation_actor"
          },
          {
            "edge_id": "world_to_collector",
            "from_node": "shared_world_simulation_actor",
            "message_type": "shared_world_result",
            "to_node": "motion_result_collector"
          },
          {
            "edge_id": "collector_to_visualizer",
            "from_node": "motion_result_collector",
            "message_type": "shared_world_collection",
            "to_node": "motion_visualization_actor"
          }
        ],
        "seed_inputs": {
          "ingress": [
            {
              "adversaries": 75,
              "description": "Run one shared MPE world with many coexisting agents that collide, chase, flee, and crowd around obstacles.",
              "good_agents": 25,
              "max_cycles": 60,
              "obstacles": 8,
              "policy_mode": "swarm",
              "scenario": "pettingzoo_simple_tag_shared_world",
              "seed": 4200,
              "total_agents": 100
            }
          ]
        },
        "side_effect": "internal_write",
        "start_workers": [
          "ingress"
        ],
        "strategy": "fanout_reduce",
        "type": "team",
        "workers": [
          {
            "id": "ingress",
            "model": "ollama/nemotron3:33b",
            "role": "Ingress",
            "uses": "mn-agents.control_router@1"
          },
          {
            "id": "motion_result_collector",
            "model": "ollama/nemotron3:33b",
            "role": "Collector",
            "uses": "mn-agents.control_join@1"
          },
          {
            "id": "motion_visualization_actor",
            "model": "ollama/nemotron3:33b",
            "role": "Visualizer",
            "uses": "mn-agents.data_python_executor@1",
            "with": {
              "command": [
                "python3.11",
                "scripts/build_shared_world_visualization.py"
              ],
              "name_prefix": "mpe-crowd-visualizer",
              "node_type": "reduce",
              "output_message_type": null,
              "pass_env": [
                "PATH"
              ],
              "runner_module": "MirrorNeuron.Runner.HostLocal",
              "script": "scripts/build_shared_world_visualization.py",
              "tty": false,
              "upload_as": "visualizer",
              "upload_path": "visualizer",
              "workdir": "/sandbox/job/visualizer"
            }
          },
          {
            "id": "shared_world_simulation_actor",
            "model": "ollama/nemotron3:33b",
            "role": "Shared World",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      },
      "write_final_artifact": {
        "risk": "low",
        "side_effect": "internal_write",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "artifact_writer",
            "model": "ollama/nemotron3:33b",
            "role": "Write result and final artifact to the local run store",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      }
    },
    "memory": {},
    "models": {
      "primary": {
        "model": "ollama/nemotron3:33b",
        "provider": "ollama",
        "role": "World simulator and visualization summarizer.",
        "type": "llm"
      }
    },
    "observability": {
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "schema_version": "mn.blueprint.observability_dashboard.v1",
      "source": "local_run_store"
    },
    "resources": {
      "cpu": {
        "min_cores": 1
      },
      "disk": {
        "min_gb": 1
      },
      "gpu": {
        "min_count": 0
      },
      "memory": {
        "min_gb": 2
      }
    },
    "store": {
      "artifacts": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ],
      "path": "./runs/${run_id}",
      "type": "local_run_store"
    },
    "worker_defaults": {
      "pool": "default",
      "pool_slots": 1,
      "runner": "MirrorNeuron.Runner.HostLocal",
      "uses": "mn-agents.data_python_executor@1",
      "workdir": "/sandbox/job/workflow"
    }
  },
  "term": "TERM.md",
  "version": 1,
  "workflow": {
    "dynamic": {
      "apply_at": "between_steps",
      "enabled": false,
      "patch_events": []
    },
    "edges": [
      {
        "accepts": [
          "done"
        ],
        "event": "inputs_loaded",
        "from": "load_inputs",
        "id": "load_inputs_to_run_workflow",
        "required": true,
        "to": "run_workflow"
      },
      {
        "accepts": [
          "done"
        ],
        "event": "workflow_result_ready",
        "from": "run_workflow",
        "id": "run_workflow_to_write_final_artifact",
        "required": true,
        "to": "write_final_artifact"
      }
    ],
    "entrypoint": "load_inputs",
    "execution": {
      "strategy": "serial"
    },
    "mode": "static_dag",
    "observers": [],
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "reject",
        "enabled": true,
        "events": {
          "decision": "human_decision_applied",
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout"
        },
        "mode": "notice_only",
        "timeout_seconds": null
      },
      "safety": {
        "blocked_actions": [],
        "default": "allow",
        "rules": []
      }
    },
    "schema": "mn.workflow.problem_graph/v1",
    "sink": "write_final_artifact",
    "source": "load_inputs",
    "state": {
      "final_artifact": {},
      "resolved_inputs": {},
      "workflow_result": {}
    },
    "steps": [
      {
        "action": "load_inputs",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "inputs_loaded",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "id": "load_inputs",
        "in": {},
        "kind": "stage",
        "label": "Load Inputs",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs"
      },
      {
        "action": "run_blueprint_workflow",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": null,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "workflow_result_ready",
        "goal": "Multi-agent coordination depends on changing positions, goals, and collisions; users need visual traces, not only scalar metrics.",
        "id": "run_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "kind": "stage",
        "label": "Run Workflow",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow"
      },
      {
        "action": "write_final_artifact",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "final_artifact_written",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "id": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "kind": "stage",
        "label": "Write Final Artifact",
        "on": {
          "final_artifact_written": "completed"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact"
      }
    ],
    "workflow_id": "robot_motion_planning_assistant_v1"
  }
}
