{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_policy_feedback_optimization_loop",
    "name": "Policy Feedback Optimization Loop"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "episodes": 5,
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Policy optimization agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe reward and incidents",
      "adjust the policy",
      "avoid overfitting to one tick"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Fraud thresholds, safety policies, routing rules, pricing guardrails.",
    "problem_solved": "Policies that look good once can fail over time; users need to see reward, coverage, and incidents evolve under each adjustment.",
    "target_users": "Developers and policy owners testing adaptive decision rules."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Policy recommendation with reward trajectory and action history.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "tighten_policy",
      "relax_policy",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "reward",
      "incident_rate",
      "policy_threshold",
      "coverage"
    ],
    "objective": "maximize",
    "primary_metric": "reward",
    "risk_metric": "incident_rate",
    "seed_field": "seed",
    "type": "Policy feedback simulation."
  },
  "standard_version": "1.0"
}
