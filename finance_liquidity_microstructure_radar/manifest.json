  "metadata": {
    "blueprint_id": "finance_liquidity_microstructure_radar",
    "category": "finance",
    "customizable_for": "Equities, crypto, FX, liquidity monitoring, trading operations.",
    "description": "Watch simulated market microstructure and produce live liquidity-risk explanations.",
    "interfaces": {
      "config": [
        "metadata",
        "identity",
