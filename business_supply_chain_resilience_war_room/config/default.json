{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "business_supply_chain_resilience_war_room",
    "name": "Supply Chain Resilience War Room"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "daily_demand_units": 650,
      "optimization_budget_usd": 65000,
      "product": "industrial sensor",
      "region": "Northeast",
      "seed": 42,
      "target_inventory_days": 22,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Supply chain disruption response agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "monitor inventory and demand",
      "choose mitigation actions",
      "produce an operations recommendation"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "optimization_model_solved",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "business",
    "customizable_for": "Manufacturing, retail, healthcare supplies, logistics networks.",
    "problem_solved": "Demand spikes and supplier delays compound over time; static dashboards show the fire but do not optimize budget-constrained mitigation paths.",
    "target_users": "Supply chain operators, procurement leaders, and operations executives."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Disruption response plan with optimized mitigation quantities, action history, and supplier-lane ranking.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "expedite_freight",
      "switch_supplier",
      "allocate_inventory"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "inventory_days",
      "demand_index",
      "supplier_delay_days",
      "service_level"
    ],
    "objective": "maximize",
    "optimization_model": {
      "enabled": true,
      "language": "Pyomo",
      "model_type": "linear_program",
      "name": "supply_chain_resilience_lp",
      "solver": "appsi_highs"
    },
    "primary_metric": "service_level",
    "risk_metric": "supplier_delay_days",
    "seed_field": "seed",
    "type": "Inventory, demand, supplier-delay, and Pyomo optimization simulation."
  },
  "standard_version": "1.0"
}
