  "name": "Demo: Cluster Reliability Service",
  "policies": {
    "constraints": [
      {
        "attribute": "node_role",
        "operator": "==",
        "value": "runtime"
      },
      {
        "attribute": "capabilities",
        "operator": "contains",
        "value": "cluster-reliability-demo"
      }
    ],
    "drain": {
      "completion_target": "maintenance",
      "deadline_ms": 30000,
      "ignore_system_jobs": true
    },
    "job_type": "service",
    "recovery_mode": "cluster_recover",
    "reschedule": {
      "attempts": 0,
      "delay_function": "fibonacci",
      "delay_ms": 5000,
      "interval_ms": 600000,
      "max_delay_ms": 60000,
      "unlimited": true
    },
    "restart": {
      "attempts": 2,
      "delay_function": "exponential",
      "delay_ms": 1000,
      "interval_ms": 600000,
      "max_delay_ms": 10000,
      "mode": "fail"
    },
    "scheduler_strategy": "spread"
  },
  "required_services": [
    {
      "name": "mn-reliability-demo",
      "origin": "internal",
      "required": false,
      "tags": [
        "reliability"
      ]
    }
  ],
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "runtime": {
    "bindings": {
      "load_inputs": {
        "risk": "low",
        "side_effect": "read",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "input_adapter",
            "model": "ollama/nemotron3:33b",
            "role": "Resolve mock, JSON, file, or env_json inputs",
            "uses": "mn-agents.data_python_executor@1.0.0"
          }
        ]
      },
      "run_workflow": {
        "risk": "medium",
        "routes": [
          {
            "edge_id": "ingress_to_placement_planner",
            "from_node": "reliability_intake_router",
            "message_type": "cluster_reliability_start",
            "to_node": "placement_planning_actor"
          },
          {
            "edge_id": "placement_planner_to_replayable_service_worker",
            "from_node": "placement_planning_actor",
            "message_type": "placement_plan_ready",
            "to_node": "service_replay_actor"
          },
          {
            "edge_id": "replayable_service_worker_to_drain_batch_worker",
            "from_node": "service_replay_actor",
            "message_type": "service_probe_ready",
            "to_node": "drain_test_actor"
          },
          {
            "edge_id": "drain_batch_worker_to_unsafe_recovery_gate",
            "from_node": "drain_test_actor",
            "message_type": "drain_probe_ready",
            "to_node": "recovery_review_actor"
          },
          {
            "edge_id": "unsafe_recovery_gate_to_reliability_report_sink",
            "from_node": "recovery_review_actor",
            "message_type": "recovery_review_required",
            "to_node": "reliability_report_sink"
          }
        ],
        "seed_inputs": {
          "cluster_reliability_ingress": [
            {
              "drain_deadline_ms": 30000,
              "local_node_hint": "mn1@local",
              "remote_node_hint": "mn2@192.168.4.173",
              "scenario": "two_box_combined_cluster"
            }
          ]
        },
        "side_effect": "internal_write",
        "start_workers": [
          "cluster_reliability_ingress"
        ],
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "service_replay_actor",
            "kind": "stream",
            "model": "ollama/nemotron3:33b",
            "role": "replayable_service",
            "uses": "mn-agents.data_python_executor@1.0.0"
          }
        ]
      },
      "write_final_artifact": {
        "risk": "low",
        "side_effect": "internal_write",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "artifact_writer",
            "model": "ollama/nemotron3:33b",
            "role": "Write result and final artifact to the local run store",
            "uses": "mn-agents.data_python_executor@1.0.0"
          }
        ]
      }
    },
    "memory": {},
    "models": {
      "primary": {
        "model": "ollama/nemotron3:33b",
        "provider": "ollama",
        "role": "Reliability management demo narrator",
        "type": "llm"
      }
