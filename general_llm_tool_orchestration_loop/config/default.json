{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_llm_tool_orchestration_loop",
    "name": "Llm Tool Orchestration Loop"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "seed": 42,
      "steps": 5,
      "tool": "moving_window_forecast"
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Tool-using planning agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "call the forecast tool",
      "compare forecast with current state",
      "choose an action with rationale"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Demand planning, capacity management, operational forecasting, scheduling.",
    "problem_solved": "LLMs are more useful when they can combine reasoning with tools and then observe whether the tool-informed decision worked.",
    "target_users": "Developers adding tools, forecasts, or deterministic calculators to agent workflows."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Tool-use trace and resource recommendation.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "use_forecast_rebalance",
      "add_buffer",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "forecast_error",
      "demand_pressure",
      "resource_buffer",
      "service_level"
    ],
    "objective": "maximize",
    "primary_metric": "service_level",
    "risk_metric": "forecast_error",
    "seed_field": "seed",
    "type": "Tool-informed resource simulation."
  },
  "standard_version": "1.0"
}
