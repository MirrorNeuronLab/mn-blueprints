{
  "manifest_version": "1.0",
  "graph_id": "general_context_memory_basic_v1",
  "job_name": "context-memory-basic",
  "entrypoints": ["planner_node"],
  "initial_inputs": {
    "planner_node": [
      {
        "request_id": "demo-context-001",
        "job_id": "job_ctx_123",
        "goal": "Analyze network traffic by pinging 127.0.0.1 twice."
      }
    ]
  },
  "nodes": [
    {
      "node_id": "planner_node",
      "agent_type": "executor",
      "type": "generic",
      "role": "planner",
      "config": {
        "name_prefix": "planner-worker",
        "from": "base",
        "upload_path": "planner",
        "upload_as": "planner",
        "workdir": "/sandbox/job/planner",
        "command": ["bash", "-c", "pip install protobuf grpcio openai && python3 scripts/planner.py"],
        "pool": "default",
        "pool_slots": 1,
        "output_message_type": "plan_ready",
        "no_keep": true,
        "no_auto_providers": true,
        "tty": false,
        "env": {"OPENAI_API_KEY": {"$ref": "env.OPENAI_API_KEY"}}
      }
    },
    {
      "node_id": "executor_node",
      "agent_type": "executor",
      "type": "generic",
      "role": "executor",
      "config": {
        "name_prefix": "executor-worker",
        "from": "base",
        "upload_path": "executor",
        "upload_as": "executor",
        "workdir": "/sandbox/job/executor",
        "command": ["bash", "-c", "pip install protobuf grpcio openai && python3 scripts/executor.py"],
        "pool": "default",
        "pool_slots": 1,
        "output_message_type": "execution_result",
        "no_keep": true,
        "no_auto_providers": true,
        "tty": false,
        "env": {"OPENAI_API_KEY": {"$ref": "env.OPENAI_API_KEY"}}
      }
    },
    {
      "node_id": "result_sink",
      "agent_type": "aggregator",
      "type": "reduce",
      "config": {
        "complete_on_message": true
      }
    }
  ],
  "edges": [
    {
      "edge_id": "planner_to_executor",
      "from_node": "planner_node",
      "to_node": "executor_node",
      "message_type": "plan_ready"
    },
    {
      "edge_id": "executor_to_sink",
      "from_node": "executor_node",
      "to_node": "result_sink",
      "message_type": "execution_result"
    }
  ],
  "policies": {
    "recovery_mode": "local_restart"
  }
}
