{
  "apiVersion": "mn.workflow/v1",
  "kind": "Workflow",
  "id": "ai_audit_readiness",
  "name": "AI Audit Readiness",
  "version": "1.0.0",
  "manifest_version": "1.0",
  "description": "Use this blueprint to turn AI and cyber control requirements into an evidence-backed readiness pack your team can review before audit or launch.",
  "graph_id": "ai_audit_readiness_v1",
  "job_name": "ai-audit-readiness",
  "contract": {
    "summary": "Use this blueprint to turn AI and cyber control requirements into an evidence-backed readiness pack your team can review before audit or launch.",
    "users": [
      "Financial services, healthcare, aerospace, defense, public sector contractors, enterprise AI, and cybersecurity teams."
    ],
    "inputs": {
      "audit_findings": {
        "type": "list",
        "required": true,
        "description": "Domain input value for audit_findings.",
        "example": [
          "No retained evidence for human escalation testing.",
          "Vendor security package is incomplete.",
          "Privileged access review is older than the quarterly target."
        ],
        "privacy": "internal"
      },
      "control_framework": {
        "type": "list",
        "required": true,
        "description": "Domain input value for control_framework.",
        "example": [
          {
            "domain": "governance",
            "id": "AI-01",
            "requirement": "Maintain approved AI system inventory"
          },
          {
            "domain": "model risk",
            "id": "AI-02",
            "requirement": "Document human review and escalation controls"
          },
          {
            "domain": "cyber",
            "id": "CY-01",
            "requirement": "Review privileged access at least quarterly"
          },
          {
            "domain": "third party",
            "id": "TP-01",
            "requirement": "Retain vendor security and privacy evidence"
          }
        ],
        "privacy": "internal"
      },
      "evidence_items": {
        "type": "list",
        "required": true,
        "description": "Domain input value for evidence_items.",
        "example": [
          {
            "control_id": "AI-01",
            "name": "Draft inventory export",
            "strength": "medium"
          },
          {
            "control_id": "CY-01",
            "name": "Last access review",
            "strength": "weak"
          }
        ],
        "privacy": "internal"
      },
      "policies": {
        "type": "list",
        "required": true,
        "description": "Domain input value for policies.",
        "example": [
          {
            "name": "AI Governance Policy",
            "text": "# AI Governance Policy\nHigh-risk AI systems require model inventory, owner approval, human review, monitoring, incident response, and retained evidence."
          },
          {
            "name": "Cloud Security Standard",
            "text": "# Cloud Security Standard\nProduction workloads require privileged access review, encryption, logging, vendor due diligence, and change approval."
          }
        ],
        "privacy": "internal"
      },
      "program": {
        "type": "str",
        "required": true,
        "description": "Domain input value for program.",
        "example": "Enterprise GenAI Claims Assistant",
        "privacy": "internal"
      },
      "system_architecture": {
        "type": "str",
        "required": true,
        "description": "Domain input value for system_architecture.",
        "example": "User request -> claims assistant -> retrieval service -> policy engine -> human adjuster queue -> audit log.",
        "privacy": "internal"
      },
      "target_readiness_score": {
        "type": "int",
        "required": true,
        "description": "Domain input value for target_readiness_score.",
        "example": 85,
        "privacy": "internal"
      }
    },
    "input_adapters": {
      "default": "mock",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "resolved_artifact": "inputs.json"
    },
    "outputs": {
      "profile": "standard_run_store",
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "type": "final_artifact",
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ]
      },
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "type": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "path": "web_ui.json",
          "mime_type": "application/json",
          "producer": "web_ui",
          "source_refs": [
            "run.json"
          ]
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        }
      ]
    },
    "events": {
      "stream": "events.jsonl",
      "human_stream": "human.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_step_attempt_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "control_readiness_pack"
      ]
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": false,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "privacy": {
      "default_classification": "internal",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    }
  },
  "flow": {
    "entrypoint": "load_inputs",
    "state": {
      "resolved_inputs": {},
      "workflow_result": {},
      "final_artifact": {}
    },
    "steps": [
      {
        "id": "load_inputs",
        "kind": "stage",
        "label": "Load Inputs",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "action": "load_inputs",
        "in": {},
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs",
        "emits": "inputs_loaded",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "run_workflow",
        "kind": "stage",
        "label": "Run Workflow",
        "goal": "Regulated companies need to prove that AI, cyber, cloud, ERP, or operational changes are safe, compliant, auditable, and controlled.",
        "action": "run_blueprint_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow",
        "emits": "workflow_result_ready",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "control": {
          "required": true,
          "timeout_seconds": null,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "write_final_artifact",
        "kind": "stage",
        "label": "Write Final Artifact",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "action": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact",
        "emits": "final_artifact_written",
        "on": {
          "final_artifact_written": "completed"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      }
    ],
    "graph": {
      "schema": "mn.workflow.problem_graph/v1",
      "mode": "static_dag",
      "source": "load_inputs",
      "sink": "write_final_artifact",
      "execution": {
        "strategy": "serial"
      },
      "dynamic": {
        "enabled": false,
        "patch_events": [],
        "apply_at": "between_steps"
      },
      "edges": [
        {
          "id": "load_inputs_to_run_workflow",
          "from": "load_inputs",
          "to": "run_workflow",
          "event": "inputs_loaded",
          "required": true,
          "accepts": [
            "done"
          ]
        },
        {
          "id": "run_workflow_to_write_final_artifact",
          "from": "run_workflow",
          "to": "write_final_artifact",
          "event": "workflow_result_ready",
          "required": true,
          "accepts": [
            "done"
          ]
        }
      ]
    },
    "policy": {
      "safety": {
        "default": "allow",
        "blocked_actions": [
          "approve_remediation_plan",
          "accept_control_exception",
          "change_governance_policy"
        ],
        "rules": []
      },
      "human": {
        "enabled": true,
        "mode": "approval_required",
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "reject",
        "timeout_seconds": 3600,
        "events": {
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout",
          "decision": "human_decision_applied"
        }
      },
      "failure": {
        "default": "fail_closed"
      }
    },
    "observers": []
  },
  "runtime": {
    "store": {
      "type": "local_run_store",
      "path": "./runs/${run_id}",
      "artifacts": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "worker_defaults": {
      "uses": "mn-agents.data_python_executor@1.0.0",
      "runner": "MirrorNeuron.Runner.HostLocal",
      "pool": "default",
      "pool_slots": 1,
      "workdir": "/sandbox/job/workflow"
    },
    "bindings": {
      "load_inputs": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "read",
        "risk": "low",
        "workers": [
          {
            "id": "input_adapter",
            "role": "Resolve mock, JSON, file, or env_json inputs"
          }
        ]
      },
      "run_workflow": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "internal_write",
        "risk": "medium",
        "workers": [
          {
            "id": "readiness_workflow",
            "role": "root_coordinator",
            "uses": "mn-agents.data_python_executor@1.0.0",
            "kind": "generic",
            "with": {
              "command": [
                "python3",
                "scripts/run_blueprint.py"
              ],
              "from": "base",
              "name_prefix": "ai-audit-readiness",
              "no_auto_providers": true,
              "no_keep": true,
              "node_type": "generic",
              "output_message_type": "control_readiness_pack",
              "pool": "default",
              "pool_slots": 1,
              "role": "root_coordinator",
              "script": "scripts/run_blueprint.py",
              "tty": false,
              "upload_as": "readiness_workflow",
              "upload_path": "readiness_workflow",
              "upload_paths": [
                {
                  "source": "readiness_workflow",
                  "target": "readiness_workflow"
                },
                {
                  "source": "config",
                  "target": "config"
                },
                {
                  "source": "mn-skills/blueprint_support_skill",
                  "target": "mn-skills/blueprint_support_skill"
                },
                {
                  "source": "mn-skills/document_reading_skill",
                  "target": "mn-skills/document_reading_skill"
                },
                {
                  "source": "mn-skills/implementation_plan_skill",
                  "target": "mn-skills/implementation_plan_skill"
                },
                {
                  "source": "mn-skills/process_map_skill",
                  "target": "mn-skills/process_map_skill"
                },
                {
                  "source": "mn-skills/client_report_skill",
                  "target": "mn-skills/client_report_skill"
                }
              ],
              "workdir": "/sandbox/job/readiness_workflow"
            }
          }
        ],
        "routes": [
          {
            "edge_id": "readiness_to_sink",
            "from_node": "readiness_workflow",
            "message_type": "control_readiness_pack",
            "to_node": "result_sink"
          }
        ],
        "start_workers": [
          "readiness_workflow"
        ],
        "seed_inputs": {
          "readiness_workflow": [
            {
              "program": "Enterprise GenAI Claims Assistant",
              "target_readiness_score": 85
            }
          ]
        }
      },
      "write_final_artifact": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "internal_write",
        "risk": "low",
        "workers": [
          {
            "id": "artifact_writer",
            "role": "Write result and final artifact to the local run store"
          }
        ]
      }
    },
    "models": {
      "primary": {
        "type": "llm",
        "provider": "ollama",
        "model": "ollama/nemotron3:33b",
        "role": "AI, cyber, and control readiness agent"
      }
    },
    "memory": {},
    "resources": {
      "cpu": {
        "min_cores": 1
      },
      "gpu": {
        "min_count": 0
      },
      "memory": {
        "min_gb": 2
      },
      "disk": {
        "min_gb": 1
      }
    },
    "observability": {
      "schema_version": "mn.blueprint.observability_dashboard.v1",
      "source": "local_run_store",
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ]
    }
  },
  "input_validation": {
    "rules": []
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "policies": {
    "recovery_mode": "local_restart"
  },
  "license": "LICENSE.md",
  "term": "TERM.md",
  "metadata": {
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "readiness_workflow",
          "uses": "mn-agents.data_python_executor@1.0.0"
        },
        {
          "node_id": "result_sink",
          "uses": "mn-agents.control_join@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "ai_audit_readiness",
    "category": "business",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json",
        "knowledge/"
      ],
      "required_files": [
        "manifest.json",
        "README.md",
        "SPEC.md",
        "config/default.json",
        "payloads/",
        "LICENSE.md",
        "TERM.md"
      ]
    },
    "customizable_for": "AI governance, cyber readiness, cloud change assurance, ERP controls, RMF/ATO preparation, and operational control advisory.",
    "description": "Use this blueprint to turn AI and cyber control requirements into an evidence-backed readiness pack your team can review before audit or launch.",
    "documentation": {
      "catalog": "../README.md",
      "config": "config/default.json",
      "manifest": "manifest.json",
      "overrides": "config/overwrite.json",
      "payloads": "payloads/",
      "readme": "README.md",
      "spec": "SPEC.md",
      "standard": "../../mn-docs/blueprint-standard.md"
    },
    "human_control": {
      "allowed_decisions": [
        "approve",
        "revise",
        "reject"
      ],
      "blocked_actions": [
        "approve_remediation_plan",
        "accept_control_exception",
        "change_governance_policy"
      ],
      "decision_event": "human_decision_applied",
      "default_action": "reject",
      "enabled": true,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "approval_required",
      "reason": "This blueprint can recommend high-impact operational, security, compliance, financial, or code actions.",
      "request_event": "human_input_requested",
      "response_event": "human_input_received",
      "timeout_event": "human_input_timeout",
      "timeout_seconds": 3600
    },
    "init_config_review": {
      "checks": [
        "identity",
        "mode",
        "inputs",
        "streams",
        "input_skills",
        "outputs",
        "privacy",
        "budgets"
      ],
      "fields": [
        {
          "default": "mock",
          "description": "Run mode used for mock, test, or real-adapter execution.",
          "label": "Run mode",
          "path": "mode"
        },
        {
          "default": "mock",
          "description": "Input source adapter. Mock is safe for demos; real inputs use json, file, env_json, streams, or connector profiles.",
          "label": "Input adapter",
          "path": "inputs.adapter"
        },
        {
          "default": "~/.mn/runs",
          "description": "Local run-store root for logs, events, inputs, outputs, and final artifacts.",
          "label": "Run-store root",
          "path": "outputs.run_root"
        },
        {
          "default": "approval_required",
          "description": "Whether this blueprint disables human control, emits notice-only events, or requires approval for high-impact actions.",
          "label": "Human control mode",
          "path": "human_control.mode"
        },
        {
          "default": false,
          "description": "Whether the shared run-store dashboard should be available for this run.",
          "label": "Web UI",
          "path": "web_ui.enabled"
        },
        {
          "default": "http://192.168.4.173:11434",
          "description": "LLM endpoint used by LLM-backed agents.",
          "label": "LLM API base",
          "path": "llm.configs.primary.api_base"
        },
        {
          "default": "ollama/nemotron3:33b",
          "description": "LLM model used by LLM-backed agents.",
          "label": "LLM model",
          "path": "llm.configs.primary.model"
        }
      ],
      "required": true
    },
    "input_contract": {
      "description": "Use this blueprint to turn AI and cyber control requirements into an evidence-backed readiness pack your team can review before audit or launch.",
      "optional_inputs": [],
      "privacy_classification": "internal",
      "profiles": {
        "env_json": {
          "adapter": "env_json",
          "description": "JSON object loaded from MN_BLUEPRINT_INPUT_JSON."
        },
        "file": {
          "adapter": "file",
          "description": "JSON object loaded from a local file path."
        },
        "json": {
          "adapter": "json",
          "description": "Inline JSON object supplied through config or runtime overrides."
        },
        "mock": {
          "adapter": "mock",
          "description": "Synthetic AI/cyber/control readiness packet with policies, frameworks, evidence, and audit findings.",
          "payload": {
