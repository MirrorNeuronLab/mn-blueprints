      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/run_llm_step.py",
          "codegen",
          "1"
        ],
        "environment": {
          "LITELLM_API_BASE": "http://192.168.4.173:11434",
          "LITELLM_API_KEY": "",
          "LITELLM_MODEL": "ollama/nemotron3:33b",
          "MN_LLM_API_BASE": "http://192.168.4.173:11434",
          "MN_LLM_API_KEY": "",
          "MN_LLM_MODEL": "ollama/nemotron3:33b"
        },
        "from": "base",
        "max_attempts": 2,
        "name_prefix": "codegen-r1",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "codegen_round_1_result",
        "pass_env": [
          "LITELLM_MODEL",
          "LITELLM_API_BASE",
          "LITELLM_API_KEY",
          "MN_LLM_MODEL",
          "MN_LLM_API_BASE",
          "MN_LLM_API_KEY"
        ],
        "pool": "default",
        "pool_slots": 1,
        "retry_backoff_ms": 500,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "tty": false,
        "upload_as": "llm_worker",
        "upload_path": "llm_worker",
