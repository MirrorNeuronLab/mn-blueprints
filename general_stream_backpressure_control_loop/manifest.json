{
  "daemon": true,
  "description": "Show bounded queues, slow workers, and retry-later behavior in a live stream.",
  "edges": [
    {
      "edge_id": "ingress_to_source",
      "from_node": "ingress",
      "message_type": "stream_start",
      "to_node": "live_source"
