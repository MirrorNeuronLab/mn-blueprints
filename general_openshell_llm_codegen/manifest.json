  "initial_inputs": {
    "codegen_round_1": [
      {
        "task_id": "log-anomaly-detector",
        "title": "Log Anomaly Detector CLI with Dynamic Helper",
        "description": "Create a Python 3 script named log_analyzer.py. The script must parse a web server log file passed with --log-file. Instead of doing all the parsing in pure Python, the script MUST dynamically create an auxiliary bash script named /tmp/log_parser_helper.sh that uses standard Unix tools (like grep/awk) to filter lines containing the word 'ERROR' or 'WARN'. The Python script should then execute this helper script via subprocess, read its output, and print a JSON summary containing total_errors, total_warnings, and unique_error_ips.",
        "requirements": [
          "Use only the Python standard library.",
          "Dynamically write a bash script to /tmp/log_parser_helper.sh and make it executable using os.chmod.",
          "The bash script must take the log file path as its first argument ($1), filter for 'ERROR' and 'WARN', and output the results to stdout.",
          "Assume standard log format where IP is the first space-separated token.",
          "Execute the bash script using subprocess.run and process its output in Python.",
          "Output valid JSON to stdout containing total_errors, total_warnings, and a list of unique_error_ips (strings).",
          "Expose a main() entrypoint guarded by if __name__ == '__main__'.",
          "The bash script must include a valid shebang (e.g. #!/bin/bash)."
        ],
        "sample_log": "192.168.1.10 - - [22/Apr/2026:10:00:00 +0000] \"GET / HTTP/1.1\" 200 512\n10.0.0.5 - - [22/Apr/2026:10:01:00 +0000] \"POST /api HTTP/1.1\" 500 128 ERROR: database timeout\n192.168.1.11 - - [22/Apr/2026:10:02:00 +0000] \"GET /img.png HTTP/1.1\" 404 256 WARN: file not found\n10.0.0.5 - - [22/Apr/2026:10:03:00 +0000] \"GET /api HTTP/1.1\" 500 128 ERROR: database timeout\n",
        "validation": {
          "expected": {
            "total_errors": 2,
            "total_warnings": 1,
            "unique_error_ips": [
              "10.0.0.5"
            ]
          }
        }
      }
    ]
  },
