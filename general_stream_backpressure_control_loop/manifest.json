      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object or MirrorNeuron event envelope"
    },
    "problem_solved": "Real event streams overload workers; agent runtimes need visible backpressure and safe rejection semantics.",
    "quick_test": {
      "description": "The daemon uses a local generated telemetry stream and local slow worker; no third-party APIs are called.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "backpressure",
      "bounded queues",
      "retry-later input",
      "stream metrics"
    ],
    "simulation_type": "Live stream with bounded queues.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "description": "mn blueprint run writes slow-agent and backpressure events to /tmp/mn_<job_id>/run.log.",
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "streaming": {
      "backpressure": {
        "drop_policy": "skip_with_error",
        "llm": {
          "max_calls_per_minute": 30,
          "max_concurrent_calls": 2
        },
        "max_concurrency": 4,
        "max_events_per_second": 25,
        "queue_size": 1000
      },
      "kind": "data",
      "primary_stream": "load_test_ingress",
      "transport": "websocket",
      "websocket_skill": true
    },
    "target_user": "Platform teams designing reliable live agent systems."
  },
  "name": "Stream Backpressure Control Loop",
  "nodes": [
    {
      "agent_type": "router",
      "config": {
        "backpressure": {
          "high_watermark": 8,
          "low_watermark": 3,
          "max_queue_depth": 16,
          "retry_after_ms": 250
        },
        "emit_type": "stream_start"
      },
      "node_id": "ingress",
      "role": "root_coordinator",
      "type": "generic",
      "uses": "mn-agents.router_agent@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 8,
          "low_watermark": 3,
          "max_queue_depth": 16,
          "retry_after_ms": 250
        },
        "emit_type": "stream_start",
        "node_type": "generic",
        "role": "root_coordinator"
      }
    },
    {
      "agent_type": "module",
      "config": {
        "backpressure": {
          "high_watermark": 8,
          "low_watermark": 3,
          "max_queue_depth": 16,
          "retry_after_ms": 250
        },
        "interval_ms": 250,
        "module": "MirrorNeuron.Examples.StreamLiveBackpressure.LiveSource",
        "module_source": "beam_modules/live_source.ex",
        "stream_id": "bp-live",
        "target_node": "slow_enricher"
      },
      "node_id": "live_source",
      "role": "source",
      "type": "stream",
      "uses": "mn-agents.module_agent@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 8,
          "low_watermark": 3,
          "max_queue_depth": 16,
          "retry_after_ms": 250
        },
        "interval_ms": 250,
        "module": "MirrorNeuron.Examples.StreamLiveBackpressure.LiveSource",
        "module_source": "beam_modules/live_source.ex",
        "node_type": "stream",
        "role": "source",
        "stream_id": "bp-live",
        "target_node": "slow_enricher"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "backpressure": {
          "high_watermark": 2,
          "low_watermark": 1,
          "max_queue_depth": 4,
          "retry_after_ms": 750
        },
        "command": [
          "python3",
          "scripts/slow_enrich.py"
        ],
        "environment": {
          "SLOW_MS": "1200"
        },
        "output_message_type": "enriched_event",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_as": "slow",
        "upload_path": "slow",
        "workdir": "/sandbox/job/slow"
      },
      "node_id": "slow_enricher",
      "role": "processor",
      "type": "stream",
      "uses": "mn-agents.python_executor@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 2,
          "low_watermark": 1,
          "max_queue_depth": 4,
          "retry_after_ms": 750
        },
        "environment": {
          "SLOW_MS": "1200"
        },
        "node_type": "stream",
        "output_message_type": "enriched_event",
        "role": "processor",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/slow_enrich.py",
        "upload_path": "slow"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "backpressure": {
          "high_watermark": 2,
          "low_watermark": 1,
          "max_queue_depth": 5,
          "retry_after_ms": 500
        },
        "command": [
          "python3",
          "scripts/collect_metrics.py"
        ],
        "environment": {
          "SINK_SLOW_MS": "450"
        },
        "output_message_type": null,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_as": "sink",
        "upload_path": "sink",
        "workdir": "/sandbox/job/sink"
      },
      "node_id": "metrics_sink",
      "role": "sink",
      "type": "stream",
      "uses": "mn-agents.python_executor@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 2,
          "low_watermark": 1,
          "max_queue_depth": 5,
          "retry_after_ms": 500
        },
        "environment": {
          "SINK_SLOW_MS": "450"
        },
        "node_type": "stream",
        "output_message_type": null,
        "role": "sink",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/collect_metrics.py",
        "upload_path": "sink"
      }
    }
  ],
  "policies": {
    "backpressure": {
      "external_input": "retry_later",
      "propagation": "downstream_to_upstream",
      "strategy": "bounded_queue"
    },
    "recovery_mode": "cluster_recover",
    "stream_mode": "live"
  },
  "requiredContextEngine": false
}
