  "llm": {
    "agent_role": "User Activity RMF Triage Assistant actor team",
    "agents": {
      "artifact_writer": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the artifact writer for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Artifact Writer"
      },
      "input_adapter": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the input adapter for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Input Adapter"
      },
      "rmf_triage_analyst": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the rmf triage analyst for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "RMF Triage Analyst"
      }
    },
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "Interpret runtime state as a role-based actor, not as a stateless function.",
      "Preserve source evidence, run-store events, and human-control boundaries.",
      "Prepare reviewable findings without taking irreversible actions."
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "agent_beacon",
      "actor_activity",
      "workflow_graph_compiled",
      "workflow_finished"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "user_activity_rmf_triage_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "metadata": {
    "blueprint_id": "user_activity_rmf_triage_assistant",
    "blueprint_revision": "v1",
    "category": "security",
    "customizable_for": "Identity provider events, SaaS audit logs, GitHub audit logs, CloudTrail, and internal application activity streams.",
    "name": "User Activity RMF Triage Assistant",
    "problem_solved": "User activity streams need stateful triage, safe response instructions, and audit-ready evidence tied to source events.",
    "standard_version": "1.0",
    "target_users": "Security-conscious SaaS, GovTech, defense-tech, compliance, and platform teams."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Machine-readable result and user-facing final artifact written to the local run store.",
    "artifacts": [
      "security_decision.json",
      "evidence_report.json",
      "incident_summary.md"
    ],
    "path": "outputs",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "default_input": {
      "adapter": "file",
