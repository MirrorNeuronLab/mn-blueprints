  "llm": {
    "agent_role": "Reliability management demo narrator",
    "agents": {},
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "summarize scheduler and recovery evidence",
      "highlight unsafe automatic recovery boundaries",
      "prepare an operator review checklist"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "metadata": {
    "blueprint_id": "cluster_reliability_simulation",
    "category": "engineering",
    "customizable_for": "Two-box labs, edge clusters, GPU worker pools, service monitors, batch pipelines, and planned maintenance drills.",
    "name": "Cluster Reliability Simulation",
    "problem_solved": "Cluster reliability behavior is hard to validate from individual unit tests; operators need one compact blueprint that can rehearse placement, restart, reschedule, drain, maintenance, service health, and safe pause behavior on a small combined cluster.",
    "standard_version": "1.0",
    "target_users": "Runtime engineers, cluster operators, and reliability evaluators."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Cluster reliability rehearsal report with scheduler, recovery, service, drain, and maintenance evidence.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
