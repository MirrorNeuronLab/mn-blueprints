    "name": "Cluster Reliability Management Lab",
    "output": "Cluster reliability rehearsal report, scheduler plan checks, recovery policy matrix, drain runbook, and operator evidence checklist.",
    "output_contract": {
      "events": "cluster_reliability_start, placement_plan_ready, service_probe_ready, drain_probe_ready, recovery_review_required",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "stdout": "JSON probe result with demonstrated reliability features and operator checks"
    },
    "problem_solved": "Cluster reliability behavior is hard to validate from individual unit tests; operators need one compact blueprint that can rehearse placement, restart, reschedule, drain, maintenance, service health, and safe pause behavior on a small combined cluster.",
    "quick_test": "Render the manifest, plan it against two nodes with cluster-reliability-demo and replayable-work capabilities, then run drain and maintenance dry runs against the remote node.",
    "runtime_features": [
      "Nomad-inspired service job lifecycle",
      "spread and binpack scheduler planning",
      "resource-aware node placement",
      "capability and attribute constraints",
      "per-agent restart policy overrides",
      "reschedule policy with unlimited service recovery",
      "cluster_recover reliability strategy",
      "node drain and maintenance runbook",
      "system and sysbatch demo variants",
      "service registry and health-check rehearsal",
      "recovery eval and blocked-placement evidence",
      "idempotency markers for replayable work"
    ],
    "simulation_type": "Two-node cluster reliability rehearsal with scheduler and recovery evidence.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load metadata -> resolve config -> plan cluster placement -> run reliability probes -> rehearse drain/maintenance -> emit evidence",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "json",
        "file",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "target_user": "Runtime engineers and operators validating MirrorNeuron cluster recovery across local and remote machines."
  },
  "name": "Cluster Reliability Management Lab",
  "nodes": [
    {
      "constraints": [
        {
          "attribute": "node_role",
          "operator": "==",
          "value": "runtime"
        }
      ],
      "node_id": "cluster_reliability_ingress",
      "resources": {
        "cpu_cores": 0.1,
        "disk_mb": 16,
        "memory_mb": 64
      },
      "uses": "mn-agents.control_router@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 6,
          "low_watermark": 2,
          "max_queue_depth": 24,
          "retry_after_ms": 400
        },
        "emit_type": "cluster_reliability_start",
        "node_type": "map",
        "role": "root_coordinator"
      }
    },
    {
      "constraints": [
        {
          "attribute": "capabilities",
          "operator": "contains",
          "value": "cluster-reliability-demo"
        }
      ],
      "node_id": "placement_planner",
      "policies": {
        "restart": {
          "attempts": 1,
          "delay_function": "constant",
          "delay_ms": 500,
          "interval_ms": 120000,
          "max_delay_ms": 500,
          "mode": "fail"
        }
      },
      "resources": {
        "cpu_cores": 0.5,
        "disk_mb": 128,
        "memory_mb": 256,
        "ports": [
          {
            "label": "probe_http",
            "port": 18080,
            "protocol": "http"
          }
        ]
      },
      "services": [
        {
          "checks": [
            {
              "command": [
                "python3",
                "scripts/reliability_demo.py",
                "--health-check"
              ],
              "interval_ms": 10000,
              "name": "planner-script-health",
              "required": false,
              "timeout_ms": 2000,
              "type": "script"
            }
          ],
          "name": "mn-reliability-planner",
          "origin": "internal",
          "port": "${env.MN_PORT_PROBE_HTTP}",
          "provider": "mirror_neuron",
          "tags": [
            "planner",
            "reliability"
          ]
        }
      ],
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 6,
          "low_watermark": 2,
          "max_queue_depth": 24,
          "retry_after_ms": 400
        },
        "environment": {
          "MN_RELIABILITY_DEMO_FEATURES": "scheduler,resources,constraints,services",
          "MN_RELIABILITY_DEMO_PHASE": "placement"
        },
        "name_prefix": "mn-reliability-placement",
        "node_type": "map",
        "output_message_type": "placement_plan_ready",
        "role": "scheduler_probe",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/reliability_demo.py",
        "upload_path": "reliability_probe"
      }
    },
    {
      "constraints": [
        {
          "attribute": "status",
          "operator": "!=",
          "value": "maintenance"
        }
      ],
      "node_id": "replayable_service_worker",
      "policies": {
        "reschedule": {
          "attempts": 0,
          "delay_function": "exponential",
          "delay_ms": 5000,
          "interval_ms": 600000,
          "max_delay_ms": 120000,
          "unlimited": true
        },
        "restart": {
          "attempts": 3,
          "delay_function": "exponential",
          "delay_ms": 1000,
          "interval_ms": 300000,
          "max_delay_ms": 15000,
          "mode": "fail"
        }
      },
      "resources": {
        "cpu_cores": 0.75,
        "disk_mb": 128,
        "memory_mb": 512
      },
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 4,
          "low_watermark": 1,
          "max_queue_depth": 12,
          "retry_after_ms": 750
        },
        "environment": {
          "MN_RELIABILITY_DEMO_FEATURES": "restart,reschedule,cluster_recover,idempotency",
          "MN_RELIABILITY_DEMO_PHASE": "service"
        },
        "idempotency_key": "cluster-reliability-service-probe-v1",
        "idempotent": true,
        "name_prefix": "mn-reliability-service",
        "node_type": "stream",
        "output_message_type": "service_probe_ready",
        "role": "replayable_service",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "safe_to_retry": true,
        "script": "scripts/reliability_demo.py",
        "upload_path": "reliability_probe"
      }
    },
    {
      "constraints": [
        {
          "attribute": "capabilities",
          "operator": "contains",
          "value": "replayable-work"
        }
      ],
      "node_id": "drain_batch_worker",
      "policies": {
        "reschedule": {
          "attempts": 1,
          "delay_function": "constant",
          "delay_ms": 5000,
          "interval_ms": 86400000,
          "max_delay_ms": 5000,
          "unlimited": false
        },
        "restart": {
          "attempts": 1,
          "delay_function": "fibonacci",
          "delay_ms": 1000,
          "interval_ms": 86400000,
          "max_delay_ms": 5000,
          "mode": "fail"
        }
      },
      "resources": {
        "cpu_cores": 0.5,
        "disk_mb": 128,
        "memory_mb": 384
      },
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "backpressure": {
          "high_watermark": 6,
          "low_watermark": 2,
          "max_queue_depth": 24,
          "retry_after_ms": 400
        },
        "environment": {
          "MN_RELIABILITY_DEMO_FEATURES": "batch_wait,deadline,migration,drain",
          "MN_RELIABILITY_DEMO_PHASE": "drain"
        },
        "idempotency_key": "cluster-reliability-drain-batch-v1",
        "name_prefix": "mn-reliability-batch",
        "node_type": "map",
        "output_message_type": "drain_probe_ready",
        "role": "drain_batch_probe",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "safe_to_retry": true,
        "script": "scripts/reliability_demo.py",
        "upload_path": "reliability_probe"
      }
    },
    {
      "constraints": [
        {
          "attribute": "node_role",
          "operator": "==",
          "value": "runtime"
        }
      ],
      "node_id": "unsafe_recovery_gate",
      "resources": {
        "cpu_cores": 0.1,
        "disk_mb": 16,
        "memory_mb": 64
      },
      "uses": "mn-agents.control_approval_gate@1.0.0",
      "with": {
        "approval_mode": "manual_on_recovery",
        "approver": "cluster-operator",
        "node_type": "map",
        "output_message_type": "recovery_review_required",
        "role": "safety_gate",
        "timeout_seconds": 120
      }
    },
    {
      "constraints": [
        {
          "attribute": "node_role",
          "operator": "==",
          "value": "runtime"
        }
      ],
      "node_id": "reliability_report_sink",
      "resources": {
        "cpu_cores": 0.1,
        "disk_mb": 16,
        "memory_mb": 64
      },
      "uses": "mn-agents.control_join@1.0.0",
      "with": {
        "complete_on_message": true,
        "node_type": "reduce",
        "role": "result_sink"
      }
    }
  ],
  "policies": {
    "constraints": [
      {
        "attribute": "node_role",
        "operator": "==",
        "value": "runtime"
      },
      {
        "attribute": "capabilities",
        "operator": "contains",
        "value": "cluster-reliability-demo"
      }
    ],
    "drain": {
      "completion_target": "maintenance",
      "deadline_ms": 30000,
      "ignore_system_jobs": true
    },
    "job_type": "service",
    "recovery_mode": "cluster_recover",
    "reschedule": {
      "attempts": 0,
      "delay_function": "fibonacci",
      "delay_ms": 5000,
      "interval_ms": 600000,
      "max_delay_ms": 60000,
      "unlimited": true
    },
    "restart": {
      "attempts": 2,
      "delay_function": "exponential",
      "delay_ms": 1000,
      "interval_ms": 600000,
      "max_delay_ms": 10000,
      "mode": "fail"
    },
    "scheduler_strategy": "spread"
  },
  "required_services": [
    {
      "name": "mn-reliability-demo",
      "origin": "internal",
      "required": false,
      "tags": [
        "reliability"
      ]
    }
  ],
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "services": [
    {
      "meta": {
        "blueprint_id": "general_cluster_reliability_management_lab",
        "role": "catalog-level-demo-service"
      },
      "name": "mn-reliability-demo",
      "origin": "internal",
      "provider": "mirror_neuron",
      "tags": [
        "reliability",
        "demo",
        "service"
      ]
    }
  ],
  "term": "TERM.md",
  "type": "service"
}
