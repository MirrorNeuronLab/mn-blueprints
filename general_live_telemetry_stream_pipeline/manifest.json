{
  "daemon": true,
  "description": "Move live telemetry chunks through stream workers and summarize the evolving signal.",
  "edges": [
    {
      "edge_id": "ingress_to_source",
      "from_node": "ingress",
      "message_type": "stream_start",
      "to_node": "telemetry_source"
    },
    {
      "edge_id": "source_to_detector",
      "from_node": "telemetry_source",
      "message_type": "telemetry_chunk",
      "to_node": "peak_detector"
    }
  ],
  "entrypoints": [
    "ingress"
  ],
  "graph_id": "general_live_telemetry_stream_pipeline_v1",
  "init_config_review": {
    "fields": [
      {
        "default": "sensor-alpha",
        "description": "Telemetry source identifier.",
        "label": "Device ID",
        "path": "telemetry.device_id"
      },
      {
        "default": 1000,
        "description": "Milliseconds between telemetry chunks.",
        "label": "Interval ms",
        "path": "telemetry.interval_ms"
      },
      {
        "default": "gzip",
        "description": "Telemetry chunk encoding: gzip or identity.",
        "label": "Content encoding",
        "path": "telemetry.content_encoding"
      },
      {
        "default": 2.4,
        "description": "Sensitivity multiplier for peak detection.",
        "label": "Spike multiplier",
        "path": "peak_detection.spike_multiplier"
      },
      {
        "default": 20.0,
        "description": "Minimum absolute signal jump to count as a spike.",
        "label": "Min spike delta",
        "path": "peak_detection.min_spike_delta"
      }
    ],
    "instruction": "Review telemetry source and peak detection settings before launching the stream pipeline.",
    "required": false
  },
  "initial_inputs": {
    "ingress": [
      {
        "description": "Continuously produce gzipped NDJSON telemetry chunks between stream agents until manually cancelled.",
        "scenario": "telemetry_stream"
      }
    ]
  },
  "job_name": "general-live-telemetry-stream-pipeline",
  "manifest_version": "1.0",
  "metadata": {
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "ingress",
          "uses": "mn-agents.control_router@1.0.0"
        },
        {
          "node_id": "telemetry_source",
          "uses": "mn-agents.data_module@1.0.0"
        },
        {
          "node_id": "peak_detector",
          "uses": "mn-agents.data_python_executor@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "general_live_telemetry_stream_pipeline",
    "category": "general",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json"
      ],
      "required_files": [
