{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_closed_loop_agent_runtime",
    "name": "Closed Loop Agent Runtime"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "initial_backlog": 18,
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Operations loop controller",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe queue pressure",
      "choose a bounded action",
      "explain the expected state impact"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Support queues, claim processing, review pipelines, fulfillment operations.",
    "problem_solved": "Most LLM demos stop after one answer; real operations require repeated observations, decisions, state updates, and traceable outcomes.",
    "target_users": "Developers, evaluators, and technical buyers learning the closed-loop agent model."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Simulation summary with action history, state deltas, and next steps.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "increase_capacity",
      "focus_quality",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "backlog",
      "capacity",
      "quality_score",
      "operating_cost"
    ],
    "objective": "minimize",
    "primary_metric": "backlog",
    "risk_metric": "quality_score",
    "seed_field": "seed",
    "type": "Time-stepped operations queue simulation."
  },
  "standard_version": "1.0"
}
