{
  "agents": {
    "edges": [
      {
        "edge_id": "ingress_to_monitor",
        "from_node": "ingress",
        "message_type": "network_events",
        "to_node": "threat_monitoring_actor"
      },
      {
        "edge_id": "monitor_to_approval",
        "from_node": "threat_monitoring_actor",
        "message_type": "security_alarm",
        "to_node": "security_approval_actor"
      },
      {
        "edge_id": "approval_to_alert_sink",
        "from_node": "security_approval_actor",
        "message_type": "approved_security_alarm",
        "to_node": "security_alert_sink"
      },
      {
        "edge_id": "security_alert_sink_to_report_sink",
        "from_node": "security_alert_sink",
        "message_type": "security_alert_sink_result",
        "to_node": "report_sink"
      }
    ],
    "entrypoints": [
      "ingress"
    ],
    "nodes": [
      {
        "agent_type": "router",
        "config": {
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Ingress",
        "node_id": "ingress",
        "role": "Ingress",
        "type": "map"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "command": [
            "python3.11",
            "scripts/run_blueprint.py"
          ],
          "environment": {
            "MN_BLUEPRINT_ID": "network_threat_response_assistant",
            "MN_RUN_MODE": "dry_run"
          },
          "node_type": "generic",
          "output_message_type": "security_alarm",
          "pool": "default",
          "pool_slots": 1,
          "role": "network_security_monitor",
          "runner_module": "MirrorNeuron.Runner.HostLocal",
          "script": "scripts/run_blueprint.py",
          "upload_as": "network_monitor",
          "upload_path": "network_monitor",
          "workdir": "/sandbox/job/network_monitor"
        },
        "display_name": "Threat Monitoring Actor",
        "node_id": "threat_monitoring_actor",
        "role": "network_security_monitor",
        "type": "generic"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Security Approval Actor",
        "node_id": "security_approval_actor",
        "role": "Security Approval Actor",
        "type": "generic"
      },
      {
        "agent_type": "aggregator",
        "config": {},
        "node_id": "security_alert_sink",
        "role": "Security Alert Sink",
        "type": "reduce"
      },
      {
        "agent_type": "aggregator",
        "config": {
          "complete_on_message": true,
          "complete_run": true,
          "terminal_sink": true
        },
        "node_id": "report_sink",
        "role": "Report sink",
        "type": "reduce"
      }
    ],
    "schema": "mn.agents.communication_graph/v1"
  },
  "apiVersion": "mn.workflow/v1",
  "contract": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_step_attempt_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
