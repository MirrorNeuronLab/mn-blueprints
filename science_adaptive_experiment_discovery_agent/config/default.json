{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "science_adaptive_experiment_discovery_agent",
    "name": "Adaptive Experiment Discovery Agent"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "compound_family": "synthetic enzyme candidate",
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Experimental design scientist",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe prior experiment outcomes",
      "choose the next experiment",
      "summarize scientific tradeoffs"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "science",
    "customizable_for": "Biology, chemistry, materials, formulation, process optimization.",
    "problem_solved": "Experiment planning is sequential; each result changes the next best experiment and the cost-risk tradeoff.",
    "target_users": "Lab researchers, R&D teams, computational scientists, and scientific AI builders."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Experiment optimization plan with ranked experiment options.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "explore_high_temp",
      "refine_ph",
      "switch_catalyst"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "yield_pct",
      "toxicity_score",
      "experiment_cost",
      "evidence_confidence"
    ],
    "objective": "maximize",
    "primary_metric": "yield_pct",
    "risk_metric": "toxicity_score",
    "seed_field": "seed",
    "type": "Iterative experiment outcome simulation."
  },
  "standard_version": "1.0"
}
