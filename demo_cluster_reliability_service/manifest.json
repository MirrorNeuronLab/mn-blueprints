{
  "agents": {
    "edges": [
      {
        "edge_id": "ingress_to_placement_planner",
        "from_node": "reliability_intake_router",
        "message_type": "cluster_reliability_start",
        "to_node": "placement_planning_actor"
      },
      {
        "edge_id": "placement_planner_to_replayable_service_worker",
        "from_node": "placement_planning_actor",
        "message_type": "placement_plan_ready",
        "to_node": "service_replay_actor"
      },
      {
        "edge_id": "replayable_service_worker_to_drain_batch_worker",
        "from_node": "service_replay_actor",
        "message_type": "service_probe_ready",
        "to_node": "drain_test_actor"
      },
      {
        "edge_id": "drain_batch_worker_to_unsafe_recovery_gate",
        "from_node": "drain_test_actor",
        "message_type": "drain_probe_ready",
        "to_node": "recovery_review_actor"
      },
      {
        "edge_id": "unsafe_recovery_gate_to_reliability_report_sink",
        "from_node": "recovery_review_actor",
        "message_type": "recovery_review_required",
        "to_node": "reliability_report_sink"
      }
    ],
    "entrypoints": [
      "reliability_intake_router"
    ],
    "nodes": [
      {
        "agent_type": "router",
        "config": {
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Reliability Intake Router",
        "node_id": "reliability_intake_router",
        "role": "Reliability Intake Router",
        "type": "map"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Placement Planning Actor",
        "node_id": "placement_planning_actor",
        "role": "Placement Planning Actor",
        "type": "generic"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Service Replay Actor",
        "node_id": "service_replay_actor",
        "role": "replayable_service",
        "type": "generic"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Drain Test Actor",
        "node_id": "drain_test_actor",
        "role": "Drain Test Actor",
        "type": "generic"
      },
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000,
          "runner_module": "MirrorNeuron.Runner.HostLocal"
        },
        "display_name": "Recovery Review Actor",
        "node_id": "recovery_review_actor",
        "role": "Recovery Review Actor",
        "type": "generic"
      },
      {
        "agent_type": "aggregator",
        "config": {},
        "node_id": "reliability_report_sink",
        "role": "Reliability Report Sink",
        "type": "reduce"
      }
    ],
    "schema": "mn.agents.communication_graph/v1"
  },
  "apiVersion": "mn.workflow/v1",
  "contract": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_step_attempt_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "cluster_reliability_start",
        "placement_plan_ready",
        "service_probe_ready",
        "drain_probe_ready",
        "recovery_review_required",
        "workflow_finished",
        "agent_beacon",
        "actor_activity"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "drain_deadline_ms": {
        "description": "Domain input value for drain_deadline_ms.",
        "example": 30000,
        "privacy": "internal",
        "required": true,
        "type": "int"
      },
      "local_node_hint": {
        "description": "Domain input value for local_node_hint.",
        "example": "mn1@local",
        "privacy": "internal",
        "required": true,
        "type": "str"
      },
      "remote_node_hint": {
        "description": "Domain input value for remote_node_hint.",
        "example": "mn2@192.168.4.173",
        "privacy": "internal",
        "required": true,
        "type": "str"
      },
      "scenario": {
        "description": "Domain input value for scenario.",
        "example": "two_box_combined_cluster",
        "privacy": "internal",
        "required": true,
        "type": "str"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "internal",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": true,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
