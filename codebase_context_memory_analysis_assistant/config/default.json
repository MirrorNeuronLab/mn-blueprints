  "llm": {
    "agent_role": "Repo architect, dependency mapper, risk classifier, context compressor, briefing author.",
    "agents": {
      "architecture_interpreter": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the architecture interpreter for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Architecture Interpreter"
      },
      "artifact_writer": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the artifact writer for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Artifact Writer"
      },
      "briefing_reviewer": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the briefing reviewer for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Briefing Reviewer"
      },
      "context_compression_planner": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the context compression planner for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Context Compression Planner"
