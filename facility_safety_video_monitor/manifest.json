{
  "description": "Use this blueprint to watch an approved camera stream, detect visible people, summarize what is observable, and raise safety alerts with a reviewable event trail.",
  "edges": [
    {
      "edge_id": "ingress_to_tick_source",
      "from_node": "ingress",
      "message_type": "video_monitor_start",
      "to_node": "door_camera_tick_source"
    },
    {
      "edge_id": "tick_source_to_person_detector",
      "from_node": "door_camera_tick_source",
      "message_type": "door_camera_frame_tick",
      "to_node": "person_detector"
    }
  ],
  "entrypoints": [
    "ingress"
  ],
  "graph_id": "facility_safety_video_monitor_v1",
  "initial_inputs": {
    "ingress": [
      {
        "description": "Continuously sample a 24/7 door camera or local webcam stream, ask the configured VL model whether a human is visible, describe observable appearance and activity, and send Slack alerts when a human is detected.",
        "ollama_base_url": "http://192.168.4.173:11434",
        "ollama_model": "nemotron3:33b",
        "scenario": "door_camera_safety_monitor",
        "slack_optional": true,
        "video_source_codec": "h264",
        "video_source_transport": "rtsp",
        "video_source_uri": "rtsp://host.docker.internal:8554/local-camera",
        "vl_model_base_url": "http://192.168.4.173:11434",
        "vl_model_name": "nemotron3:33b"
      }
    ]
  },
  "input_validation": {
    "rules": [
      {
        "message": "video_source.uri must be an rtsp:// or rtsps:// URL.",
        "name": "video_source_uri_rtsp",
        "path": "video_source.uri",
        "pattern": "^rtsps?://",
        "type": "pattern"
      },
      {
        "command": [
          "python3",
          "payloads/validation/validate_rtsp_source.py"
        ],
        "name": "video_source_rtsp_probe",
        "timeout_seconds": 12,
        "type": "command"
      }
    ]
  },
