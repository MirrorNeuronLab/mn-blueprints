    "llm_agent_role": "Native BEAM monitoring agents.",
    "name": "Native Live Monitor Daemon",
    "output": "Streaming monitor events and summaries.",
    "output_contract": {
      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "Some simulations and monitors need low-overhead native agents that can run continuously and emit structured updates.",
    "quick_test": {
      "description": "Use generated quick-test bundles when available; fixed blueprints use local dry-run/mock provider environment variables and deterministic sample inputs.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "native agents",
      "daemon mode",
      "streaming events",
      "low-overhead simulation"
    ],
    "simulation_type": "Live native signal monitor.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "streaming": {
      "backpressure": {
        "drop_policy": "skip_with_error",
        "llm": {
          "max_calls_per_minute": 30,
          "max_concurrent_calls": 2
        },
        "max_concurrency": 4,
        "max_events_per_second": 25,
        "queue_size": 1000
      },
      "kind": "data",
      "primary_stream": "monitor_ingress",
      "transport": "websocket",
      "websocket_skill": true
    },
    "target_user": "Runtime evaluators comparing native BEAM agents with external worker processes."
  },
  "name": "Native Live Monitor Daemon",
  "nodes": [
    {
      "agent_type": "module",
      "config": {
        "answer_node": "answer_agent",
        "interval_ms": 10000,
        "max_x": 500,
        "max_y": 25,
        "min_x": 10,
        "min_y": 2,
        "module": "MirrorNeuron.Examples.DivisibilityMonitor.QuestionGenerator",
        "module_source": "beam_modules/question_generator.ex"
      },
      "node_id": "question_generator",
      "role": "question_source",
      "type": "stream"
    },
    {
      "agent_type": "module",
      "config": {
        "module": "MirrorNeuron.Examples.DivisibilityMonitor.AnswerAgent",
        "module_source": "beam_modules/answer_agent.ex"
      },
      "node_id": "answer_agent",
      "role": "answer_sink",
      "type": "stream"
    }
  ],
  "policies": {
    "recovery_mode": "local_restart"
  },
  "requiredContextEngine": false
}
