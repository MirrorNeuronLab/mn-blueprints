  "entrypoints": [
    "codegen_round_1"
  ],
  "graph_id": "general_sandboxed_llm_codegen_review_loop_v1",
  "initial_inputs": {
    "codegen_round_1": [
      {
        "description": "Create a Python 3 script named inventory_report.py. The script must read a JSON array of inventory records from a file passed with --input or from stdin when --input is omitted. Each record has sku, category, quantity, and price. The CLI must support --format text|json and --low-stock-threshold (default 5).",
        "requirements": [
          "Use only the Python standard library.",
          "Include a pure function build_report(records, low_stock_threshold=5).",
          "The JSON output must include total_quantity, total_value, category_totals, and low_stock_skus.",
          "Category totals must be sorted alphabetically by category name.",
          "low_stock_skus must be sorted alphabetically.",
          "Round total_value to two decimal places.",
          "Expose a main() entrypoint and guard it with if __name__ == '__main__'."
        ],
        "sample_records": [
          {
            "category": "books",
            "price": 12.5,
            "quantity": 3,
            "sku": "A-100"
          },
          {
            "category": "books",
            "price": 8.0,
            "quantity": 7,
            "sku": "B-200"
          },
          {
            "category": "games",
            "price": 59.99,
            "quantity": 2,
            "sku": "C-300"
          }
        ],
        "task_id": "inventory-report-cli",
        "title": "Inventory report CLI",
        "validation": {
          "expected": {
            "category_totals": [
              {
                "category": "books",
                "quantity": 10
              },
              {
                "category": "games",
                "quantity": 2
              }
            ],
            "low_stock_skus": [
              "A-100",
              "C-300"
            ],
            "total_quantity": 12,
            "total_value": 213.48
          },
          "low_stock_threshold": 4
        }
      }
    ]
  },
  "job_name": "general-sandboxed-llm-codegen-review-loop",
  "manifest_version": "1.0",
  "metadata": {
    "blueprint_id": "general_sandboxed_llm_codegen_review_loop",
    "category": "general",
    "customizable_for": "Internal developer tools, data scripts, code repair, controlled automation.",
    "description": "Generate, review, and validate code through a sandboxed multi-step LLM loop.",
    "interfaces": {
      "config": [
        "metadata",
        "identity",
        "inputs",
        "simulation",
        "llm",
        "outputs",
        "logging",
        "real_adapters"
      ],
      "identity": [
        "blueprint_id",
        "name",
        "run_id"
      ],
      "input_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "output_adapters": [
        "local_run_store"
      ],
      "outputs": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "llm": {},
    "llm_agent_role": "Codegen agent, review agent, validator.",
    "name": "Sandboxed Llm Codegen Review Loop",
    "output": "Generated code, review history, and validation result.",
    "output_contract": {
      "events": "typed event objects with payload",
      "status": "sent to stderr as JSON lines",
      "stdout": "single JSON object or bundle path"
    },
    "problem_solved": "One-shot code generation is risky; production teams need review, validation, isolation, and iterative improvement before executing generated code.",
    "quick_test": {
      "description": "Uses smaller deterministic inputs and local mock providers where external resources are optional.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "LLM agents",
      "sandbox validation",
      "multi-round loop",
      "tool creation"
    ],
    "simulation_type": "Iterative code-review decision loop.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load metadata -> resolve config -> load inputs -> simulate/decide loop -> emit events -> write final artifact",
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "target_user": "Engineering teams evaluating safe LLM coding workflows."
  },
  "name": "Sandboxed Llm Codegen Review Loop",
