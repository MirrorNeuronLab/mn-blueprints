        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ],
      "path": "./runs/${run_id}",
      "type": "local_run_store"
    },
    "worker_defaults": {
      "pool": "default",
      "pool_slots": 1,
      "runner": "MirrorNeuron.Runner.HostLocal",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "workdir": "/sandbox/job/workflow"
    }
  },
  "services": [
    {
      "meta": {
        "blueprint_id": "demo_cluster_reliability_service",
        "role": "catalog-level-demo-service"
      },
      "name": "mn-reliability-demo",
      "origin": "internal",
      "provider": "mirror_neuron",
      "tags": [
        "reliability",
        "demo",
        "service"
      ]
    }
  ],
  "term": "TERM.md",
  "type": "service",
  "version": "1.0.0",
  "workflow": {
    "dynamic": {
      "apply_at": "between_steps",
      "enabled": false,
      "patch_events": []
    },
    "edges": [
      {
        "accepts": [
          "done"
        ],
        "event": "inputs_loaded",
        "from": "load_inputs",
        "id": "load_inputs_to_run_workflow",
        "required": true,
        "to": "run_workflow"
      },
      {
        "accepts": [
          "done"
        ],
        "event": "workflow_result_ready",
        "from": "run_workflow",
        "id": "run_workflow_to_write_final_artifact",
        "required": true,
        "to": "write_final_artifact"
      }
    ],
    "entrypoint": "load_inputs",
    "execution": {
      "strategy": "serial"
    },
    "mode": "static_dag",
    "observers": [],
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "approve",
        "enabled": false,
        "events": {
          "decision": "human_decision_applied",
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout"
        },
        "mode": "disabled",
        "timeout_seconds": null
      },
      "safety": {
        "blocked_actions": [],
        "default": "allow",
        "rules": []
      }
    },
    "schema": "mn.workflow.problem_graph/v1",
    "sink": "write_final_artifact",
    "source": "load_inputs",
    "state": {
      "final_artifact": {},
      "resolved_inputs": {},
      "workflow_result": {}
    },
    "steps": [
      {
        "action": "load_inputs",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "inputs_loaded",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "id": "load_inputs",
        "in": {},
        "kind": "stage",
        "label": "Load Inputs",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs"
      },
      {
        "action": "run_blueprint_workflow",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": null,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "workflow_result_ready",
        "goal": "Cluster reliability behavior is hard to validate from individual unit tests; operators need one compact blueprint that can rehearse placement, restart, reschedule, drain, maintenance, service health, and safe pause behavior on a small combined cluster.",
        "id": "run_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "kind": "stage",
        "label": "Run Workflow",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow"
      },
      {
        "action": "write_final_artifact",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "final_artifact_written",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "id": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "kind": "stage",
        "label": "Write Final Artifact",
        "on": {
          "final_artifact_written": "completed"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact"
      }
    ],
    "workflow_id": "demo_cluster_reliability_service_v1"
  }
