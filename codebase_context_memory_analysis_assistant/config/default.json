      "dependency_evidence_extractor": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the dependency evidence extractor for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Dependency Evidence Extractor"
      },
      "input_adapter": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the input adapter for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Input Adapter"
      },
      "repo_intake_coordinator": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the repo intake coordinator for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Repo Intake Coordinator"
      },
      "risk_classifier_actor": {
        "llm_config": "primary",
        "model": "ollama/nemotron3:33b",
        "responsibilities": [
          "Act as the risk classifier actor for the current run.",
          "Ground findings in supplied inputs, runtime events, and source references.",
          "Hand off reviewable state to the next actor without taking irreversible action."
        ],
        "role": "Risk Classifier Actor"
      }
    },
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "Interpret runtime state as a role-based actor, not as a stateless function.",
      "Preserve source evidence, run-store events, and human-control boundaries.",
      "Prepare reviewable findings without taking irreversible actions."
    ]
