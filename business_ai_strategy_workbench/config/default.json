{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills"
  ],
  "identity": {
    "blueprint_id": "business_ai_strategy_workbench",
    "name": "AI Strategy Workbench"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Synthetic consulting-discovery packet with documents, transcripts, financials, and benchmark notes.",
    "payload": {
      "company": "Northstar Industrial",
      "documents": [
        {
          "name": "annual_report_excerpt.md",
          "text": "# Annual Report Excerpt\nRevenue grew 4 percent while SG&A rose 11 percent. Management cited fragmented demand planning, manual quote approvals, and elevated cloud spend as margin headwinds."
        },
        {
          "name": "operations_policy.md",
          "text": "# Operations Policy\nPlant managers own local scheduling. Exceptions require regional VP approval. Teams maintain separate spreadsheets for maintenance backlog, supplier delays, and workforce availability."
        },
        {
          "name": "technology_assessment.md",
          "text": "# Technology Assessment\nERP data quality is uneven. Cloud tagging is incomplete. Field service teams use four workflow tools and lack a single owner for automation standards."
        }
      ],
      "engagement_goal": "Find board-ready cost, growth, risk, and technology opportunities for the next 12 months.",
      "financials_csv": "metric,baseline,target\nSG&A growth,11,6\nQuote cycle days,9,4\nCloud waste percent,18,7\nMaintenance backlog days,21,12\n",
      "market_notes": [
        {
          "claims": [
            "Industrial peers use shared services to reduce SG&A growth",
            "Quote automation improves cycle time and win-rate consistency",
            "Cloud cost governance is a near-term margin lever"
          ],
          "source": "Benchmark study"
        },
        {
          "claims": [
            "Buyers cite slow quote turnaround",
            "Service disruptions affect renewal confidence"
          ],
          "source": "Customer interviews"
        }
      ],
      "meeting_transcripts": [
        "Alex: Finance wants a clearer path to reduce SG&A without hurting service.\nPriya: Decision: focus first on quote automation and cloud cost governance.\nMina will gather owner-level process maps by Friday.\nAction item: validate savings assumptions with operations."
      ],
      "roadmap_weeks": 12
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl"
        ]
      },
      "events": {
