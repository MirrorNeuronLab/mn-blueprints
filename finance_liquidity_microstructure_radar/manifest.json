        "config.json",
        "inputs.json",
        "events.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "llm": {},
    "llm_agent_role": "Signal analyzer, market explainer, advisor agent.",
    "name": "Liquidity Microstructure Radar",
    "output": "Market signals, risk explanations, advice events, and optional Slack alerts.",
    "output_contract": {
      "events": "typed event objects with payload",
      "status": "sent to stderr as JSON lines",
      "stdout": "single JSON object or bundle path"
    },
    "problem_solved": "Markets evolve tick by tick; spreads, depth, momentum, and volatility interact faster than static dashboards or one-shot summaries can capture.",
    "quick_test": {
      "description": "Uses smaller deterministic inputs and local mock providers where external resources are optional.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "stream simulation",
      "technical signals",
      "LLM explanation",
      "live advisor loop"
    ],
    "simulation_type": "Live market stream and exchange-style signal simulation.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load metadata -> resolve config -> load inputs -> simulate/decide loop -> emit events -> write final artifact",
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "target_user": "Trading teams, market-risk analysts, and fintech product evaluators."
  },
  "name": "Liquidity Microstructure Radar",
  "nodes": [
    {
      "agent_type": "router",
      "config": {
        "emit_type": "simulation_start"
      },
      "node_id": "ingress",
      "role": "root_coordinator",
      "type": "map"
    },
    {
      "agent_type": "module",
      "config": {
        "duration_seconds": 86400,
        "initial_price": 100.0,
        "live_mode": true,
        "llm_market_data_every_ticks": 30,
        "module": "MirrorNeuron.Examples.FinancialMarket.ExchangeAgent",
        "module_source": "beam_modules/exchange_agent.ex",
        "tick_delay_ms": 1000,
        "tick_seconds": 1
      },
      "node_id": "exchange",
      "role": "exchange",
      "type": "reduce"
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/generate_stock_stream.py"
        ],
        "daily_drift": 0.001,
        "daily_volatility": 0.018,
        "environment": {
          "STOCK_STREAM_DAILY_DRIFT": "0.001",
          "STOCK_STREAM_DAILY_VOLATILITY": "0.018",
          "STOCK_STREAM_INTERVAL_MAX_MS": "1000",
          "STOCK_STREAM_INTERVAL_MIN_MS": "1000",
          "STOCK_STREAM_MAX_DAILY_MOVE": "0.06",
          "STOCK_STREAM_SEED": "729905862",
          "STOCK_STREAM_START_DATE": "2026-04-30",
          "STOCK_STREAM_SYMBOLS": "AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA",
          "STOCK_STREAM_TARGET_NODE": "stock_signal_analyzer",
          "STOCK_STREAM_TRADING_DAYS": "252"
        },
        "interval_max_ms": 1000,
        "interval_min_ms": 1000,
        "max_daily_move": 0.06,
        "output_message_type": null,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "seed": 729905862,
        "start_date": "2026-04-30",
        "symbols": [
          "AAPL",
          "MSFT",
          "NVDA",
          "GOOGL",
          "AMZN",
          "META",
          "TSLA"
        ],
        "target_node": "stock_signal_analyzer",
        "trading_days": 252,
        "upload_as": "fake_stock_stream",
        "upload_path": "fake_stock_stream",
        "workdir": "/sandbox/job/fake_stock_stream"
      },
      "node_id": "fake_stock_stream",
      "role": "fake_data_stream_agent",
      "type": "stream"
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/analyze_stock_signal.py"
        ],
        "environment": {
          "LLM_SIGNAL_EVERY_EVENTS": "30",
          "LLM_SIGNAL_MIN_CONFIDENCE": "0.72"
        },
        "output_message_type": null,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_as": "stock_signal_analyzer",
        "upload_path": "stock_signal_analyzer",
        "workdir": "/sandbox/job/stock_signal_analyzer"
      },
      "node_id": "stock_signal_analyzer",
      "role": "technical_signal_analyzer",
      "type": "stream"
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/explain_market.py"
        ],
        "environment": {
          "LITELLM_API_BASE": "http://192.168.4.173:11434",
          "LITELLM_API_KEY": "",
          "LITELLM_MAX_TOKENS": "800",
          "LITELLM_MODEL": "ollama/nemotron3:33b",
          "LITELLM_NUM_RETRIES": "2",
          "LITELLM_RETRY_BACKOFF_SECONDS": "1.0",
          "LITELLM_TIMEOUT_SECONDS": "60.0",
          "LLM_EXPLANATION_INTERVAL_EVENTS": "0",
          "LLM_EXPLANATION_INTERVAL_SECONDS": "300.0",
          "LLM_EXPLANATION_MAX_PENDING": "25",
          "LLM_EXPLANATION_RETRY_DELAY_SECONDS": "5.0",
          "MN_LLM_API_BASE": "http://192.168.4.173:11434",
          "MN_LLM_API_KEY": "",
          "MN_LLM_MAX_TOKENS": "800",
          "MN_LLM_MODEL": "ollama/nemotron3:33b",
          "MN_LLM_NUM_RETRIES": "2",
