{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "finance_claim_risk_triage_copilot",
    "name": "Claim Risk Triage Copilot"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "line": "personal auto",
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Insurance claim risk triage agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe claim queues and fraud signals",
      "prioritize reviews",
      "produce a triage report"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "finance",
    "customizable_for": "Auto, property, health, warranty, and specialty claims.",
    "problem_solved": "Claims queues evolve continuously; teams need to balance fast settlement, fraud risk, loss ratio, and adjuster capacity.",
    "target_users": "Insurance claims leaders, SIU teams, adjuster operations, and insurtech builders."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Claim triage report with prioritized segments and review actions.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "escalate_siu",
      "fast_track_low_risk",
      "request_evidence"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "claim_queue",
      "fraud_signal",
      "adjuster_capacity",
      "loss_ratio_pct"
    ],
    "objective": "minimize",
    "primary_metric": "claim_queue",
    "risk_metric": "fraud_signal",
    "seed_field": "seed",
    "type": "Claim queue and fraud-signal simulation."
  },
  "standard_version": "1.0"
}
