{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "business_dynamic_pricing_profit_optimizer",
    "name": "Dynamic Pricing Profit Optimizer"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "seed": 42,
      "sku": "connected thermostat",
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Pricing strategy agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "watch demand and competitor movement",
      "choose price actions",
      "explain revenue and inventory risk"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "business",
    "customizable_for": "Retail, travel, marketplaces, subscriptions, manufacturing quotes.",
    "problem_solved": "Pricing is dynamic and coupled: competitors, demand, inventory, and margin move together faster than static rules can explain.",
    "target_users": "Pricing teams, category managers, and revenue management leaders."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Pricing recommendation with revenue and inventory tradeoffs.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "increase_price",
      "discount_price",
      "match_competitor"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "own_price",
      "competitor_price",
      "inventory_units",
      "revenue_index"
    ],
    "objective": "maximize",
    "primary_metric": "revenue_index",
    "risk_metric": "inventory_units",
    "seed_field": "seed",
    "type": "Demand, competitor price, inventory, and revenue simulation."
  },
  "standard_version": "1.0"
}
