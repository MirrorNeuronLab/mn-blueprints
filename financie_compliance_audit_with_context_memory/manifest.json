        "upload_path": "initializer",
        "workdir": "/sandbox/job/initializer",
        "command": ["bash", "-c", "pip install protobuf grpcio && python3 scripts/init.py"],
        "pool": "default",
        "pool_slots": 1,
        "output_message_type": "init_done",
        "no_keep": true, "no_auto_providers": true, "tty": false
      }
    },
    {
