{
  "standard_version": "1.0",
  "identity": {
    "blueprint_id": "secuirty_rmf_user_activity",
    "name": "Security RMF User Activity Response Worker"
  },
  "metadata": {
    "category": "general",
    "target_users": "Security-conscious SaaS, GovTech, defense-tech, compliance, and platform teams.",
    "problem_solved": "User activity streams need stateful triage, safe response instructions, and audit-ready evidence tied to source events.",
    "customizable_for": "Identity provider events, SaaS audit logs, GitHub audit logs, CloudTrail, and internal application activity streams."
  },
  "inputs": {
    "adapter": "file",
    "description": "JSON or JSONL user activity events.",
    "path": "inputs/sample_events_high_risk.jsonl"
  },
  "outputs": {
    "adapter": "local_files",
    "path": "outputs",
    "artifacts": [
      "security_decision.json",
      "evidence_report.json",
      "incident_summary.md"
    ]
  },
  "security_worker": {
    "mode": "dry_run",
    "risk_thresholds": {
      "low": 0,
      "medium": 25,
      "high": 50,
      "critical": 80
    },
    "signal_weights": {
      "new_device_login": 15,
      "new_location_login": 15,
      "impossible_travel": 40,
      "repeated_failed_logins": 20,
      "mfa_disabled": 40,
      "api_key_created_after_risky_login": 25,
      "large_data_download": 30,
      "privilege_change": 35,
      "sensitive_file_access_after_risky_login": 25,
      "known_safe_device": -10,
      "mfa_success": -10
    },
    "response_policy": {
      "low": [
        "log_only"
      ],
      "medium": [
        "notify_admin"
      ],
      "high": [
        "step_up_authentication_required"
      ],
      "critical": [
        "require_mfa_challenge",
        "notify_admin",
        "create_incident_ticket"
      ]
    },
    "require_human_approval_for": [
      "account_lock",
      "global_session_revocation",
      "permission_removal",
      "api_key_revocation"
    ],
    "reporting": {
      "write_json": true,
      "write_markdown": true,
      "include_candidate_control_mappings": true
    }
  }
}

