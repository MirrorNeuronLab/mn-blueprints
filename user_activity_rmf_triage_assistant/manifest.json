{
  "agents": {
    "edges": [
      {
        "edge_id": "rmf_triage_analyst_to_report_sink",
        "from_node": "rmf_triage_analyst",
        "message_type": "rmf_triage_analyst_result",
        "to_node": "report_sink"
      }
    ],
    "entrypoints": [
      "rmf_triage_analyst"
    ],
    "nodes": [
      {
        "agent_type": "executor",
        "config": {
          "agent_beacon_required": true,
          "beacon_enabled": true,
          "beacon_interval_ms": 15000,
          "beacon_missed_action": "fail_attempt",
          "beacon_timeout_ms": 45000
        },
        "display_name": "RMF Triage Analyst",
        "node_id": "rmf_triage_analyst",
        "role": "root_coordinator",
        "type": "generic"
      },
      {
        "agent_type": "aggregator",
        "config": {
          "complete_on_message": true,
          "complete_run": true,
          "terminal_sink": true
        },
        "node_id": "report_sink",
        "role": "Report sink",
        "type": "reduce"
      }
    ],
    "schema": "mn.agents.communication_graph/v1"
  },
  "apiVersion": "mn.workflow/v1",
  "base_blueprint": "event_stream_triage_assistant",
  "blueprint_id": "user_activity_rmf_triage_assistant",
  "canonical_spec_name": "security_user_activity_response_worker",
  "contract": {
    "events": {
      "human_stream": "human.jsonl",
      "stream": "events.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_step_attempt_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "blueprint_report",
        "workflow_finished",
        "agent_beacon",
        "actor_activity"
      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "sample_path": {
        "description": "Domain input value for sample_path.",
        "example": "inputs/sample_events_high_risk.jsonl",
        "privacy": "internal",
        "required": true,
        "type": "str"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        }
      ],
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ],
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "type": "final_artifact"
      },
      "profile": "standard_run_store"
    },
    "privacy": {
      "default_classification": "internal",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": true,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
