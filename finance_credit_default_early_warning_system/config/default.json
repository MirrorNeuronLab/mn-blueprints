{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "finance_credit_default_early_warning_system",
    "name": "Credit Default Early Warning System"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "portfolio": "consumer installment",
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Credit risk decision agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "monitor borrower risk",
      "choose approval and pricing actions",
      "write a credit decision report"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "finance",
    "customizable_for": "Consumer lending, SMB credit, cards, mortgage prequalification.",
    "problem_solved": "Borrower behavior, rates, approvals, and yield interact over time; static scorecards miss policy tradeoffs under changing conditions.",
    "target_users": "Credit-risk teams, lenders, fintech underwriters, and portfolio analysts."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Credit risk decision report with policy action history.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "tighten_credit",
      "risk_based_pricing",
      "request_more_docs"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "default_rate_pct",
      "interest_rate_pct",
      "approval_rate_pct",
      "portfolio_yield_pct"
    ],
    "objective": "minimize",
    "primary_metric": "default_rate_pct",
    "risk_metric": "approval_rate_pct",
    "seed_field": "seed",
    "type": "Borrower default and credit policy simulation."
  },
  "standard_version": "1.0"
}
