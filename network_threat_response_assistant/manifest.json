          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "mime_type": "application/x-jsonlines",
          "path": "human.jsonl",
          "producer": "human_control",
          "schema_version": "mn.blueprint.human_events.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "human_events"
        },
        {
          "artifact_id": "output_skill_email_alarm",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "email_alarm",
          "schema_version": "mn.blueprint.output_skill_attempt.v1",
          "source_refs": [
