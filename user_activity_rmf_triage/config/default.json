{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 4,
    "max_events_per_second": 10,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 600,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "stream.subscribe"
    ],
    "required": [
      "filesystem.write"
    ]
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills"
  ],
  "human_control": {
    "allowed_decisions": [
      "approve",
      "revise",
      "reject"
    ],
    "blocked_actions": [
      "disable_account",
      "isolate_host",
      "change_access_policy",
      "escalate_to_enforcement"
    ],
    "decision_event": "human_decision_applied",
    "default_action": "reject",
    "enabled": true,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "approval_required",
    "reason": "This blueprint can recommend high-impact operational, security, compliance, financial, or code actions.",
    "request_event": "human_input_requested",
    "response_event": "human_input_received",
    "timeout_event": "human_input_timeout",
    "timeout_seconds": 3600
  },
  "identity": {
    "blueprint_id": "user_activity_rmf_triage",
    "name": "User Activity RMF Triage"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "JSON or JSONL user activity events.",
    "path": "inputs/sample_events_high_risk.jsonl",
    "payload": {
      "sample_path": "inputs/sample_events_high_risk.jsonl"
    }
  },
  "interfaces": {
    "channels": {
      "artifacts": {
        "artifacts": [
          "run.json",
          "config.json",
          "inputs.json",
          "events.jsonl",
          "result.json",
          "final_artifact.json"
        ],
        "description": "Stable run-store files and domain-specific outputs.",
        "optional_artifacts": [
          "job.json",
          "web_ui.json",
          "ui.json",
          "web/index.html",
          "logs.jsonl",
          "logs.index.json",
          "human.jsonl",
          "resources.jsonl"
        ]
      },
      "events": {
        "artifact": "events.jsonl",
        "description": "Append-only workflow events."
      },
      "human": {
        "artifact": "human.jsonl",
        "description": "Sparse human collaboration notices, input requests, and responses.",
        "mirrored_to": "events.jsonl"
      },
      "input_skills": {
        "description": "Connector-backed or reusable skill-backed input sources."
      },
      "inputs": {
        "artifact": "inputs.json",
        "description": "Resolved runtime inputs and adapter provenance."
      },
      "logs": {
        "artifact": "logs.jsonl",
        "description": "Runtime stdout/stderr and explicit log artifacts.",
        "index": "logs.index.json",
        "stream": "stdout/stderr"
      },
      "output_skills": {
        "description": "Optional fan-out destinations after local run-store writes."
      },
      "outputs": {
        "artifacts": [
          "result.json",
          "final_artifact.json"
        ],
        "description": "Primary result and final user-facing artifact."
      },
      "resources": {
        "artifact": "resources.jsonl",
        "description": "Blueprint-scoped CPU, GPU, memory, and LLM token usage samples."
      },
      "streams": {
        "default": [
          "events"
        ],
        "description": "Named data or event streams exposed by the blueprint.",
        "kinds": [
          "audio",
          "video",
          "data",
          "multimodal"
        ],
        "transports": [
          "file",
          "http",
          "https",
          "rtsp",
          "rtmp",
          "webrtc",
          "websocket",
          "socketio",
          "tcp",
          "udp",
          "sse",
          "kafka",
          "mqtt",
          "custom"
        ]
      },
      "web_ui": {
        "artifacts": [
          "web_ui.json",
          "ui.json",
          "web/index.html"
        ],
        "description": "Optional web input/output handles."
      }
    },
    "config_sections": [
      "standard_version",
      "identity",
      "mode",
      "metadata",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "resources",
      "human_control",
      "real_adapters",
      "streams",
      "input_skills",
      "output_skills",
      "error_handling",
      "state",
      "capabilities",
      "privacy",
      "triggers",
      "backpressure",
      "determinism",
      "schemas",
      "budgets",
      "agent_handoffs",
      "web_ui",
      "interfaces",
      "execution_model"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "optional_run_artifacts": [
      "job.json",
      "web_ui.json",
      "ui.json",
      "web/index.html",
      "logs.jsonl",
      "logs.index.json",
      "human.jsonl",
      "resources.jsonl"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "response_schema": "mn.blueprint.response.v1",
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ],
    "stream_kinds": [
      "audio",
      "video",
      "data",
      "multimodal"
    ],
    "stream_transports": [
      "file",
      "http",
      "https",
      "rtsp",
      "rtmp",
      "webrtc",
      "websocket",
      "socketio",
      "tcp",
      "udp",
      "sse",
      "kafka",
      "mqtt",
      "custom"
    ],
    "web_ui_adapters": [
      "none",
      "static_html",
      "gradio",
      "custom"
    ]
  },
  "llm": {
    "agents": {},
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "metadata": {
    "blueprint_id": "user_activity_rmf_triage",
    "blueprint_revision": "v1",
    "category": "general",
    "customizable_for": "Identity provider events, SaaS audit logs, GitHub audit logs, CloudTrail, and internal application activity streams.",
    "name": "User Activity RMF Triage",
    "problem_solved": "User activity streams need stateful triage, safe response instructions, and audit-ready evidence tied to source events.",
    "standard_version": "1.0",
    "target_users": "Security-conscious SaaS, GovTech, defense-tech, compliance, and platform teams."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Machine-readable result and user-facing final artifact written to the local run store.",
    "artifacts": [
      "security_decision.json",
      "evidence_report.json",
      "incident_summary.md"
    ],
    "path": "outputs",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "default_input": {
      "adapter": "file",
      "description": "JSON or JSONL user activity events.",
      "path": "inputs/sample_events_high_risk.jsonl",
      "payload": {}
    },
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "JSON or JSONL user activity events.",
      "path": "inputs/sample_events_high_risk.jsonl"
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": "auto",
    "gpu_sample_interval_seconds": 60,
    "history_window_hours": 24,
    "raw_retention_hours": 48,
    "rollup_bucket_seconds": 3600,
    "sample_interval_seconds": 10
  },
  "schemas": {
    "artifact_record": "mn.artifact.record.v1",
    "config": "mn.blueprint.config.v1",
    "events": "mn.blueprint.events.v1",
    "final_artifact": "mn.blueprint.final_artifact.v1",
    "human_control": "mn.blueprint.human_control.v1",
    "input_skills": "mn.blueprint.input_skills.v1",
    "inputs": "mn.blueprint.inputs.v1",
    "logs": "mn.blueprint.logs.v1",
    "output_skills": "mn.blueprint.output_skills.v1",
    "resources": "mn.blueprint.resources.v1",
    "status_contract": "mn.blueprint.status_contract.v1",
    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "security_worker": {
    "mode": "dry_run",
    "reporting": {
      "include_candidate_control_mappings": true,
      "write_json": true,
      "write_markdown": true
    },
    "require_human_approval_for": [
      "account_lock",
      "global_session_revocation",
      "permission_removal",
      "api_key_revocation"
    ],
    "response_policy": {
      "critical": [
        "require_mfa_challenge",
        "notify_admin",
        "create_incident_ticket"
      ],
      "high": [
        "step_up_authentication_required"
      ],
      "low": [
        "log_only"
      ],
      "medium": [
        "notify_admin"
      ]
    },
    "risk_thresholds": {
      "critical": 80,
      "high": 50,
      "low": 0,
      "medium": 25
    },
    "signal_weights": {
      "api_key_created_after_risky_login": 25,
      "impossible_travel": 40,
      "known_safe_device": -10,
      "large_data_download": 30,
      "mfa_disabled": 40,
      "mfa_success": -10,
      "new_device_login": 15,
      "new_location_login": 15,
      "privilege_change": 35,
      "repeated_failed_logins": 20,
      "sensitive_file_access_after_risky_login": 25
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed"
  },
  "standard_version": "1.0",
  "state": {
    "checkpoint_interval": {
      "events": 100,
      "seconds": 60
    },
    "enabled": false,
    "idempotency_key_fields": [
      "source_ref",
      "event_id"
    ],
    "resume_mode": "none"
  },
  "streams": {},
  "triggers": {
    "schedule": null,
    "sources": [],
    "type": "manual"
  },
  "web_ui": {
    "artifacts": [
      "web_ui.json",
      "ui.json",
      "web/index.html"
    ],
    "dashboard": {
      "data_source": "local_run_store",
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ],
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ]
    },
    "enabled": true,
    "input": {
      "adapter": "none",
      "custom_url": null,
      "fields": [],
      "host": "127.0.0.1",
      "instructions": null,
      "port": null,
      "share": false,
      "title": null
    },
    "output": {
      "adapter": "gradio",
      "auto_generate": true,
      "custom_url": null,
      "refresh_seconds": 2.0,
      "title": null
    },
    "reads_from": "local_run_store"
  }
}
