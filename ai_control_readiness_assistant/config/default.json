      ]
    },
    "enabled": false,
    "input": {
      "adapter": "none",
      "custom_url": null,
      "fields": [],
      "host": "127.0.0.1",
      "instructions": null,
      "port": null,
      "share": false,
      "title": null
    },
    "output": {
      "adapter": "none",
