    "llm": {},
    "llm_agent_role": "Stream processor and summarizer.",
    "name": "Live Telemetry Stream Pipeline",
    "output": "Signal summary and stream result artifacts.",
    "output_contract": {
      "events": "typed event objects with payload",
      "events_jsonl": "events.jsonl",
      "final_artifact_json": "final_artifact.json",
      "local_run_store": "~/.mn/runs/<run_id>/",
      "logs_jsonl": "logs.jsonl",
      "response_schema": "mn.blueprint.response.v1",
      "result_json": "result.json",
      "status": "JSON lines on stderr",
      "stdout": "single JSON object, event envelope, or bundle path"
    },
    "problem_solved": "Streaming systems require backpressure-aware routing, stateful workers, and outputs that remain interpretable as events arrive.",
    "quick_test": {
      "description": "Use generated quick-test bundles when available; fixed blueprints use local dry-run/mock provider environment variables and deterministic sample inputs.",
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "stream agents",
      "live events",
      "stateful summarization",
      "daemon mode"
    ],
    "simulation_type": "Live telemetry stream.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "streaming": {
      "backpressure": {
        "drop_policy": "skip_with_error",
        "llm": {
          "max_calls_per_minute": 30,
          "max_concurrent_calls": 2
        },
        "max_concurrency": 4,
        "max_events_per_second": 25,
        "queue_size": 1000
      },
      "kind": "data",
      "primary_stream": "telemetry_ingress",
      "transport": "websocket",
      "websocket_skill": true
    },
    "target_user": "Developers building event-stream workflows and runtime observability paths."
  },
  "name": "Live Telemetry Stream Pipeline",
  "nodes": [
    {
      "agent_type": "router",
      "config": {
        "emit_type": "stream_start"
      },
      "node_id": "ingress",
      "role": "root_coordinator",
      "type": "map",
      "uses": "mn-agents.control_router@1.0.0",
      "with": {
        "emit_type": "stream_start",
        "node_type": "map",
        "role": "root_coordinator"
      }
    },
    {
      "agent_type": "module",
      "config": {
        "baseline": 24,
        "chunk_size": 6,
        "content_encoding": "gzip",
        "device_id": "sensor-alpha",
        "interval_ms": 1000,
        "jitter": 4,
        "module": "MirrorNeuron.Examples.StreamBasicDaemon.TelemetrySource",
        "module_source": "beam_modules/telemetry_source.ex",
        "peak_every": 20,
        "peak_height": 55,
        "target_node": "peak_detector"
      },
      "node_id": "telemetry_source",
      "role": "producer",
      "type": "stream",
      "uses": "mn-agents.data_module@1.0.0",
      "with": {
        "baseline": 24,
        "chunk_size": 6,
        "content_encoding": "gzip",
        "device_id": "sensor-alpha",
        "interval_ms": 1000,
        "jitter": 4,
        "module": "MirrorNeuron.Examples.StreamBasicDaemon.TelemetrySource",
        "module_source": "beam_modules/telemetry_source.ex",
        "node_type": "stream",
        "peak_every": 20,
        "peak_height": 55,
        "role": "producer",
        "target_node": "peak_detector"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/detect_stream_peaks.py"
        ],
        "environment": {
          "MIN_SPIKE_DELTA": "20.0",
          "SPIKE_MULTIPLIER": "2.4",
          "WARMUP_POINTS": "5",
          "WINDOW_SIZE": "8"
        },
        "output_message_type": null,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_as": "stream_worker",
        "upload_path": "stream_worker",
        "workdir": "/sandbox/job/stream_worker"
      },
      "node_id": "peak_detector",
      "role": "consumer",
      "type": "stream",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "environment": {
          "MIN_SPIKE_DELTA": "20.0",
          "SPIKE_MULTIPLIER": "2.4",
          "WARMUP_POINTS": "5",
          "WINDOW_SIZE": "8"
        },
        "node_type": "stream",
        "output_message_type": null,
        "role": "consumer",
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "script": "scripts/detect_stream_peaks.py",
        "upload_path": "stream_worker"
      }
    }
  ],
  "policies": {
    "recovery_mode": "cluster_recover",
    "stream_mode": "live"
  },
  "requiredContextEngine": false
}
