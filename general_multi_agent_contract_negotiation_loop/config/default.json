{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_multi_agent_contract_negotiation_loop",
    "name": "Multi Agent Contract Negotiation Loop"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "seed": 42,
      "steps": 5,
      "target_margin_pct": 18
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Negotiation mediator agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "compare buyer and supplier constraints",
      "select the next negotiation move",
      "track agreement progress"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Procurement, renewals, vendor management, enterprise sales deal desks.",
    "problem_solved": "Negotiation is dynamic: positions change as demand, capacity, and costs move, so static summaries cannot capture the next best move.",
    "target_users": "Developers building multi-agent workflows and procurement teams evaluating negotiation automation."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Negotiation brief with agreement score, action history, and ranked deal terms.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "raise_offer",
      "bundle_volume_commitment",
      "pause_negotiation"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "agreement_score",
      "unit_price",
      "demand_index",
      "supplier_capacity"
    ],
    "objective": "maximize",
    "primary_metric": "agreement_score",
    "risk_metric": "unit_price",
    "seed_field": "seed",
    "type": "Multi-agent negotiation state simulation."
  },
  "standard_version": "1.0"
}
