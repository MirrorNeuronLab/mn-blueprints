  "llm": {
    "agent_role": "Strategy discovery and board recommendation agent",
    "agents": {
      "default": {
        "llm_config": "primary",
        "responsibilities": [
          "extract facts from client materials",
          "cluster findings into strategic themes",
          "build first-draft executive artifacts"
        ],
        "role": "Strategy discovery and board recommendation agent"
      }
    },
    "api_base": "http://192.168.4.173:11434",
    "configs": {
      "primary": {
        "api_base": "http://192.168.4.173:11434",
        "max_tokens": 700,
        "mock_mode": "fake",
        "mode": "ollama",
        "model": "ollama/nemotron3:33b",
        "num_retries": 1,
        "provider": "ollama",
        "timeout_seconds": 60
      }
    },
    "default_config": "primary",
    "enabled": true,
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "extract facts from client materials",
      "cluster findings into strategic themes",
      "build first-draft executive artifacts"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "documents_read",
      "findings_clustered",
      "recommendation_pack_generated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "stderr_jsonl": true
  },
  "metadata": {
    "blueprint_revision": "v1",
    "category": "business",
    "customizable_for": "Enterprise strategy, private-equity value creation, CFO transformation, corporate development, and transformation-office discovery.",
    "problem_solved": "Companies spend weeks collecting documents, interviewing teams, summarizing findings, and building first-draft strategy recommendations.",
    "standard_version": "1.0",
    "target_users": "Large enterprise strategy, CFO, corporate development, private-equity operating, and transformation-office teams."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Board-ready recommendation packet with summary, issue tree, opportunity map, roadmap, slide outline, and evidence appendix.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "env_json": {
      "adapter": "env_json",
      "description": "Load client-discovery packets from MN_BLUEPRINT_INPUT_JSON.",
      "env": "MN_BLUEPRINT_INPUT_JSON"
    },
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
