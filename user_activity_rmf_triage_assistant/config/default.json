    "web_ui": "mn.blueprint.web_ui.v1"
  },
  "security_worker": {
    "mode": "dry_run",
    "reporting": {
      "include_candidate_control_mappings": true,
      "write_json": true,
      "write_markdown": true
    },
    "require_human_approval_for": [
      "account_lock",
      "global_session_revocation",
      "permission_removal",
      "api_key_revocation"
    ],
    "response_policy": {
      "critical": [
        "require_mfa_challenge",
        "notify_admin",
        "create_incident_ticket"
      ],
      "high": [
        "step_up_authentication_required"
      ],
      "low": [
        "log_only"
      ],
      "medium": [
        "notify_admin"
      ]
    },
    "risk_thresholds": {
      "critical": 80,
      "high": 50,
      "low": 0,
      "medium": 25
    },
    "signal_weights": {
      "api_key_created_after_risky_login": 25,
      "impossible_travel": 40,
      "known_safe_device": -10,
      "large_data_download": 30,
      "mfa_disabled": 40,
      "mfa_success": -10,
      "new_device_login": 15,
      "new_location_login": 15,
      "privilege_change": 35,
      "repeated_failed_logins": 20,
      "sensitive_file_access_after_risky_login": 25
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed"
  },
  "standard_version": "1.0",
  "state": {
    "checkpoint_interval": {
      "events": 100,
