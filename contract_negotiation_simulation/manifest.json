{
  "apiVersion": "mn.workflow/v1",
  "kind": "Workflow",
  "id": "contract_negotiation_simulation",
  "name": "Contract Negotiation Simulation",
  "version": "1.0.0",
  "manifest_version": "1.0",
  "description": "Use this blueprint to model buyer-supplier negotiation rounds and compare offers as demand, price, and capacity change.",
  "graph_id": "contract_negotiation_simulation_v1",
  "job_name": "contract-negotiation-simulation",
  "contract": {
    "summary": "Use this blueprint to model buyer-supplier negotiation rounds and compare offers as demand, price, and capacity change.",
    "users": [
      "Developers building multi-agent workflows and procurement teams evaluating negotiation automation."
    ],
    "inputs": {
      "target_margin_pct": {
        "type": "int",
        "required": true,
        "description": "Domain input value for target_margin_pct.",
        "example": 18,
        "privacy": "internal"
      },
      "seed": {
        "type": "int",
        "required": false,
        "description": "Run control value for seed.",
        "example": 42,
        "privacy": "internal"
      },
      "steps": {
        "type": "int",
        "required": false,
        "description": "Run control value for steps.",
        "example": 5,
        "privacy": "internal"
      }
    },
    "input_adapters": {
      "default": "mock",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "resolved_artifact": "inputs.json"
    },
    "outputs": {
      "profile": "standard_run_store",
      "primary": {
        "id": "final_artifact",
        "path": "final_artifact.json",
        "type": "final_artifact",
        "schema_version": "mn.blueprint.final_artifact_contract.v1",
        "required_fields": [
          "type",
          "executive_summary",
          "recommended_action",
          "confidence",
          "evidence",
          "next_steps",
          "source_refs"
        ]
      },
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "resource_samples"
        },
        {
          "artifact_id": "web_ui",
          "mime_type": "application/json",
          "path": "web_ui.json",
          "producer": "web_ui",
          "schema_version": "mn.blueprint.web_ui.v1",
          "source_refs": [
            "run.json"
          ],
          "type": "web_ui"
        },
        {
          "artifact_id": "human_events",
          "type": "human_events",
          "schema_version": "mn.blueprint.human_events.v1",
          "path": "human.jsonl",
          "mime_type": "application/x-jsonlines",
          "producer": "human_control",
          "source_refs": [
            "events.jsonl"
          ]
        }
      ]
    },
    "events": {
      "stream": "events.jsonl",
      "human_stream": "human.jsonl",
      "types": [
        "run_started",
        "inputs_loaded",
        "workflow_graph_compiled",
        "workflow_step_started",
        "workflow_worker_completed",
        "workflow_step_completed",
        "workflow_result_ready",
        "final_artifact_written",
        "artifact_written",
        "run_completed",
        "run_failed",
        "blueprint_status",
        "blueprint_phase_started",
        "blueprint_phase_completed",
        "blueprint_phase_failed",
        "output_skill_started",
        "output_skill_completed",
        "output_skill_failed",
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied",
        "blueprint_report"
      ]
    },
    "status": {
      "event": "blueprint_status",
      "heartbeat": false,
      "phases": [
        "loading_inputs",
        "running_worker",
        "waiting_for_human",
        "writing_artifacts",
        "completed"
      ]
    },
    "privacy": {
      "default_classification": "internal",
      "rules": {
        "confidential": {
          "log": "redacted",
          "send_to_llm": "allowed_configs_only",
          "send_to_output_skills": "approved_destinations_only"
        },
        "internal": {
          "log": "metadata_only",
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "public": {
          "log": true,
          "send_to_llm": true,
          "send_to_output_skills": true
        },
        "regulated": {
          "log": "redacted",
          "send_to_llm": false,
          "send_to_output_skills": "approved_destinations_only"
        }
      }
    }
  },
  "flow": {
    "entrypoint": "load_inputs",
    "state": {
      "resolved_inputs": {},
      "workflow_result": {},
      "final_artifact": {}
    },
    "steps": [
      {
        "id": "load_inputs",
        "kind": "stage",
        "label": "Load Inputs",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "action": "load_inputs",
        "in": {},
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs",
        "emits": "inputs_loaded",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "run_workflow",
        "kind": "stage",
        "label": "Run Workflow",
        "goal": "Negotiation is dynamic: positions change as demand, capacity, and costs move, so static summaries cannot capture the next best move.",
        "action": "run_blueprint_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow",
        "emits": "workflow_result_ready",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "control": {
          "required": true,
          "timeout_seconds": null,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      },
      {
        "id": "write_final_artifact",
        "kind": "stage",
        "label": "Write Final Artifact",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "action": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact",
        "emits": "final_artifact_written",
        "on": {
          "final_artifact_written": "completed"
        },
        "control": {
          "required": true,
          "timeout_seconds": 120,
          "retry": {
            "max_attempts": 2,
            "backoff_seconds": 1,
            "backoff_multiplier": 2,
            "jitter": 0
          },
          "failure_policy": "fail_workflow",
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        }
      }
    ],
    "graph": {
      "schema": "mn.workflow.problem_graph/v1",
      "mode": "static_dag",
      "source": "load_inputs",
      "sink": "write_final_artifact",
      "execution": {
        "strategy": "serial"
      },
      "dynamic": {
        "enabled": false,
        "patch_events": [],
        "apply_at": "between_steps"
      },
      "edges": [
        {
          "id": "load_inputs_to_run_workflow",
          "from": "load_inputs",
          "to": "run_workflow",
          "event": "inputs_loaded",
          "required": true,
          "accepts": [
            "done"
          ]
        },
        {
          "id": "run_workflow_to_write_final_artifact",
          "from": "run_workflow",
          "to": "write_final_artifact",
          "event": "workflow_result_ready",
          "required": true,
          "accepts": [
            "done"
          ]
        }
      ]
    },
    "policy": {
      "safety": {
        "default": "allow",
        "blocked_actions": [],
        "rules": []
      },
      "human": {
        "enabled": false,
        "mode": "disabled",
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "approve",
        "timeout_seconds": null,
        "events": {
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout",
          "decision": "human_decision_applied"
        }
      },
      "failure": {
        "default": "fail_closed"
      }
    },
    "observers": []
  },
  "runtime": {
    "store": {
      "type": "local_run_store",
      "path": "./runs/${run_id}",
      "artifacts": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "worker_defaults": {
      "uses": "mn-agents.data_python_executor@1.0.0",
      "runner": "MirrorNeuron.Runner.HostLocal",
      "pool": "default",
      "pool_slots": 1,
      "workdir": "/sandbox/job/workflow"
    },
    "bindings": {
      "load_inputs": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "read",
        "risk": "low",
        "workers": [
          {
            "id": "input_adapter",
            "role": "Resolve mock, JSON, file, or env_json inputs"
          }
        ]
      },
      "run_workflow": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "internal_write",
        "risk": "medium",
        "workers": [
          {
            "id": "simulation_loop",
            "role": "root_coordinator",
            "uses": "mn-agents.data_python_executor@1.0.0",
            "kind": "generic",
            "with": {
              "command": [
                "python3",
                "scripts/run_blueprint.py"
              ],
              "environment": {
                "LITELLM_API_BASE": "http://192.168.4.173:11434",
                "LITELLM_MAX_TOKENS": "700",
                "LITELLM_MODEL": "ollama/nemotron3:33b",
                "LITELLM_NUM_RETRIES": "1",
                "LITELLM_TIMEOUT_SECONDS": "60",
                "MN_BLUEPRINT_ID": "contract_negotiation_simulation",
                "MN_LLM_API_BASE": "http://192.168.4.173:11434",
                "MN_LLM_MAX_TOKENS": "700",
                "MN_LLM_MODEL": "ollama/nemotron3:33b",
                "MN_LLM_NUM_RETRIES": "1",
                "MN_LLM_TIMEOUT_SECONDS": "60"
              },
              "from": "base",
              "name_prefix": "contract_negotiation_simulation",
              "no_auto_providers": true,
              "no_keep": true,
              "node_type": "generic",
              "output_message_type": "blueprint_report",
              "pool": "default",
              "pool_slots": 1,
              "role": "root_coordinator",
              "script": "scripts/run_blueprint.py",
              "tty": false,
              "upload_as": "simulation_loop",
              "upload_path": "simulation_loop",
              "workdir": "/sandbox/job/simulation_loop"
            }
          }
        ],
        "routes": [
          {
            "edge_id": "simulation_to_report",
            "from_node": "simulation_loop",
            "message_type": "blueprint_report",
            "to_node": "report_sink"
          }
        ],
        "start_workers": [
          "simulation_loop"
        ],
        "seed_inputs": {
          "simulation_loop": [
            {
              "seed": 42,
              "steps": 5,
              "target_margin_pct": 18
            }
          ]
        }
      },
      "write_final_artifact": {
        "type": "worker",
        "strategy": "single",
        "side_effect": "internal_write",
        "risk": "low",
        "workers": [
          {
            "id": "artifact_writer",
            "role": "Write result and final artifact to the local run store"
          }
        ]
      }
    },
    "models": {
      "primary": {
        "type": "llm",
        "provider": "ollama",
        "model": "ollama/nemotron3:33b",
        "role": "Negotiation mediator agent"
      }
    },
    "memory": {},
    "resources": {
      "cpu": {
        "min_cores": 1
      },
      "gpu": {
        "min_count": 0
      },
      "memory": {
        "min_gb": 2
      },
      "disk": {
        "min_gb": 1
      }
    },
    "observability": {
      "schema_version": "mn.blueprint.observability_dashboard.v1",
      "source": "local_run_store",
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ]
    }
  },
  "input_validation": {
    "rules": []
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "policies": {
    "recovery_mode": "local_restart"
  },
  "license": "LICENSE.md",
  "term": "TERM.md",
  "metadata": {
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "simulation_loop",
          "uses": "mn-agents.data_python_executor@1.0.0"
        },
        {
          "node_id": "report_sink",
          "uses": "mn-agents.control_join@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "contract_negotiation_simulation",
    "category": "general",
    "configuration_contract": {
      "optional_files": [
        "scenario.json",
        "config/overwrite.json",
        "knowledge/"
      ],
      "required_files": [
        "manifest.json",
        "README.md",
        "SPEC.md",
        "config/default.json",
        "payloads/",
        "LICENSE.md",
        "TERM.md"
      ]
    },
    "customizable_for": "Procurement, renewals, vendor management, enterprise sales deal desks.",
    "description": "Use this blueprint to model buyer-supplier negotiation rounds and compare offers as demand, price, and capacity change.",
    "documentation": {
      "catalog": "../README.md",
      "config": "config/default.json",
      "manifest": "manifest.json",
      "overrides": "config/overwrite.json",
      "payloads": "payloads/",
      "readme": "README.md",
      "spec": "SPEC.md",
      "standard": "../../mn-docs/blueprint-standard.md"
    },
    "human_control": {
      "enabled": false,
      "events": [
        "human_notice",
        "human_input_requested",
        "human_input_received",
        "human_input_timeout",
        "human_decision_applied"
      ],
      "mode": "disabled",
      "reason": "This blueprint is a low-risk runtime or simulation pattern that only writes local decision-support artifacts."
    },
    "init_config_review": {
      "checks": [
        "identity",
        "mode",
        "inputs",
        "streams",
        "input_skills",
        "outputs",
        "privacy",
        "budgets"
      ],
      "fields": [
        {
          "default": "mock",
          "description": "Run mode used for mock, test, or real-adapter execution.",
          "label": "Run mode",
          "path": "mode"
        },
        {
          "default": "mock",
          "description": "Input source adapter. Mock is safe for demos; real inputs use json, file, env_json, streams, or connector profiles.",
          "label": "Input adapter",
          "path": "inputs.adapter"
        },
        {
          "default": "~/.mn/runs",
          "description": "Local run-store root for logs, events, inputs, outputs, and final artifacts.",
          "label": "Run-store root",
          "path": "outputs.run_root"
        },
        {
          "default": "disabled",
          "description": "Whether this blueprint disables human control, emits notice-only events, or requires approval for high-impact actions.",
          "label": "Human control mode",
          "path": "human_control.mode"
        },
        {
          "default": true,
          "description": "Whether the shared run-store dashboard should be available for this run.",
          "label": "Web UI",
          "path": "web_ui.enabled"
        },
        {
          "default": "http://192.168.4.173:11434",
          "description": "LLM endpoint used by LLM-backed agents.",
          "label": "LLM API base",
          "path": "llm.configs.primary.api_base"
        },
        {
          "default": "ollama/nemotron3:33b",
          "description": "LLM model used by LLM-backed agents.",
          "label": "LLM model",
          "path": "llm.configs.primary.model"
        }
      ],
      "required": true
    },
    "input_contract": {
      "description": "Use this blueprint to model buyer-supplier negotiation rounds and compare offers as demand, price, and capacity change.",
      "optional_inputs": [
        {
          "description": "Run control value for seed.",
          "example": 42,
          "name": "seed",
          "type": "int"
        },
        {
          "description": "Run control value for steps.",
          "example": 5,
          "name": "steps",
          "type": "int"
        }
      ],
      "privacy_classification": "internal",
      "profiles": {
        "env_json": {
          "adapter": "env_json",
          "description": "JSON object loaded from MN_BLUEPRINT_INPUT_JSON."
        },
        "file": {
          "adapter": "file",
          "description": "JSON object loaded from a local file path."
        },
        "json": {
          "adapter": "json",
          "description": "Inline JSON object supplied through config or runtime overrides."
        },
        "mock": {
          "adapter": "mock",
          "description": "Default synthetic inputs bundled with the blueprint.",
          "payload": {
            "seed": 42,
            "steps": 5,
            "target_margin_pct": 18
          }
        }
      },
      "required_inputs": [
        {
          "description": "Domain input value for target_margin_pct.",
          "example": 18,
          "name": "target_margin_pct",
          "type": "int"
        }
      ],
      "resolved_artifact": "inputs.json",
      "schema_version": "mn.blueprint.input_contract.v1",
      "supported_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "validation_rules": []
    },
    "interfaces": {
      "channels": {
        "artifacts": {
          "artifacts": [
            "run.json",
            "config.json",
            "inputs.json",
            "events.jsonl",
            "result.json",
            "final_artifact.json"
          ],
          "description": "Stable run-store files and domain-specific outputs.",
          "optional_artifacts": [
            "job.json",
            "web_ui.json",
            "ui.json",
            "web/index.html",
            "logs.jsonl",
            "logs.index.json",
            "human.jsonl",
            "resources.jsonl"
          ]
        },
        "events": {
          "artifact": "events.jsonl",
          "description": "Append-only workflow events."
        },
        "human": {
          "artifact": "human.jsonl",
          "description": "Sparse human collaboration notices, input requests, and responses.",
          "mirrored_to": "events.jsonl"
        },
        "input_skills": {
          "description": "Connector-backed or reusable skill-backed input sources."
        },
        "inputs": {
          "artifact": "inputs.json",
          "description": "Resolved runtime inputs and adapter provenance."
        },
        "logs": {
          "artifact": "logs.jsonl",
          "description": "Runtime stdout/stderr and explicit log artifacts.",
          "index": "logs.index.json",
          "stream": "stdout/stderr"
        },
        "output_skills": {
          "description": "Optional fan-out destinations after local run-store writes."
        },
        "outputs": {
          "artifacts": [
            "result.json",
            "final_artifact.json"
          ],
          "description": "Primary result and final user-facing artifact."
        },
        "resources": {
          "artifact": "resources.jsonl",
          "description": "Blueprint-scoped CPU, GPU, memory, and LLM token usage samples."
        },
        "streams": {
          "default": [
            "events"
          ],
          "description": "Named data or event streams exposed by the blueprint.",
          "kinds": [
            "audio",
            "video",
            "data",
            "multimodal"
          ],
          "transports": [
            "file",
            "http",
            "https",
            "rtsp",
            "rtmp",
            "webrtc",
            "websocket",
            "socketio",
            "tcp",
            "udp",
            "sse",
