{
  "manifest_version": "1.0",
  "graph_id": "general_test_message_flow_v1",
  "job_name": "test-message-flow",
  "entrypoints": [
    "ingress"
  ],
  "initial_inputs": {
    "ingress": [
      {
        "topic": "test topic",
        "text": "Initiate test message flow."
      }
    ]
  },
  "nodes": [
    {
      "node_id": "ingress",
      "agent_type": "router",
      "type": "map",
      "role": "root_coordinator",
      "config": {
        "emit_type": "test_request"
      }
    },
    {
      "node_id": "retriever",
      "agent_type": "router",
      "type": "map",
      "role": "researcher"
    },
    {
      "node_id": "reviewer",
      "agent_type": "aggregator",
      "type": "reduce",
      "role": "result_sink",
      "config": {
        "complete_on_message": true
      }
    }
  ],
  "edges": [
    {
      "edge_id": "ingress_to_retriever",
      "from_node": "ingress",
      "to_node": "retriever",
      "message_type": "test_request"
    },
    {
      "edge_id": "retriever_to_reviewer",
      "from_node": "retriever",
      "to_node": "reviewer",
      "message_type": "test_request"
    }
  ],
  "policies": {
    "recovery_mode": "local_restart"
  },
  "metadata": {
    "blueprint_id": "general_test_message_flow",
    "status_logging": {
      "format": "jsonl",
      "stream": "stderr",
      "env": "MN_BLUEPRINT_LOG_LEVEL"
    },
    "quick_test": {
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1",
      "description": "Use generated quick-test bundles when available; fixed blueprints use local dry-run/mock provider environment variables and deterministic sample inputs."
    },
    "output_contract": {
      "stdout": "single JSON object, event envelope, or bundle path",
      "events": "typed event objects with payload",
      "status": "JSON lines on stderr"
    }
  }
}
