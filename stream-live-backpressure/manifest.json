{
  "manifest_version": "1.0",
  "graph_id": "stream_live_backpressure_v1",
  "job_name": "stream-live-backpressure",
  "daemon": true,
  "entrypoints": ["ingress"],
  "initial_inputs": {
    "ingress": [
      {
        "scenario": "stream_live_backpressure",
        "burst_count": 24,
        "description": "Emit a finite telemetry burst into a deliberately slow stream consumer."
      }
    ]
  },
  "nodes": [
    {
      "node_id": "ingress",
      "agent_type": "router",
      "type": "generic",
      "role": "root_coordinator",
      "config": {
        "emit_type": "stream_start",
        "backpressure": {
          "max_queue_depth": 16,
          "high_watermark": 8,
          "low_watermark": 3,
          "retry_after_ms": 250
        }
      }
    },
    {
      "node_id": "burst_source",
      "agent_type": "executor",
      "type": "stream",
      "role": "source",
      "config": {
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_path": "source",
        "upload_as": "source",
        "workdir": "/sandbox/job/source",
        "command": ["python3", "scripts/emit_burst.py"],
        "output_message_type": null,
        "environment": {
          "BURST_COUNT": "24",
          "STREAM_ID": "bp-demo"
        },
        "backpressure": {
          "max_queue_depth": 16,
          "high_watermark": 8,
          "low_watermark": 3,
          "retry_after_ms": 250
        }
      }
    },
    {
      "node_id": "slow_enricher",
      "agent_type": "executor",
      "type": "stream",
      "role": "processor",
      "config": {
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_path": "slow",
        "upload_as": "slow",
        "workdir": "/sandbox/job/slow",
        "command": ["python3", "scripts/slow_enrich.py"],
        "output_message_type": "enriched_event",
        "environment": {
          "SLOW_MS": "350"
        },
        "backpressure": {
          "max_queue_depth": 6,
          "high_watermark": 3,
          "low_watermark": 1,
          "retry_after_ms": 500
        }
      }
    },
    {
      "node_id": "metrics_sink",
      "agent_type": "executor",
      "type": "stream",
      "role": "sink",
      "config": {
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "upload_path": "sink",
        "upload_as": "sink",
        "workdir": "/sandbox/job/sink",
        "command": ["python3", "scripts/collect_metrics.py"],
        "output_message_type": null,
        "backpressure": {
          "max_queue_depth": 20,
          "high_watermark": 10,
          "low_watermark": 4,
          "retry_after_ms": 250
        }
      }
    }
  ],
  "edges": [
    {
      "edge_id": "ingress_to_source",
      "from_node": "ingress",
      "to_node": "burst_source",
      "message_type": "stream_start"
    },
    {
      "edge_id": "source_to_slow",
      "from_node": "burst_source",
      "to_node": "slow_enricher",
      "message_type": "telemetry_event"
    },
    {
      "edge_id": "slow_to_sink",
      "from_node": "slow_enricher",
      "to_node": "metrics_sink",
      "message_type": "enriched_event"
    }
  ],
  "policies": {
    "recovery_mode": "cluster_recover",
    "stream_mode": "live",
    "backpressure": {
      "strategy": "bounded_queue",
      "external_input": "retry_later",
      "propagation": "downstream_to_upstream"
    }
  },
  "metadata": {
    "blueprint_id": "stream-live-backpressure",
    "status_logging": {
      "format": "jsonl",
      "stream": "stderr",
      "env": "MN_BLUEPRINT_LOG_LEVEL"
    },
    "quick_test": {
      "enabled": false,
      "env": "MN_BLUEPRINT_QUICK_TEST=1",
      "description": "The demo script uses a small burst and local slow worker; no third-party APIs are called."
    },
    "output_contract": {
      "stdout": "single JSON object or MirrorNeuron event envelope",
      "events": "typed event objects with payload",
      "status": "JSON lines on stderr"
    }
  }
}
