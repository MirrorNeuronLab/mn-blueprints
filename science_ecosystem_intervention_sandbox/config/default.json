{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "science_ecosystem_intervention_sandbox",
    "name": "Ecosystem Intervention Sandbox"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {}
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters",
      "ecosystem",
      "manifest_config_bindings"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "World coordinator, regional agents, leaderboard summarizer.",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b"
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "science",
    "customizable_for": "Conservation planning, invasive species modeling, education, agent-based simulation.",
    "problem_solved": "Ecological systems change through local interactions, migration, resources, and mutation; interventions need scenario testing before field action.",
    "target_users": "Ecologists, conservation analysts, simulation researchers, and education teams."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Regional outcomes, population rankings, and ecosystem summary.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "deterministic": true,
    "enabled": true,
    "seed_field": "seed",
    "type": "Multi-region population dynamics."
  },
  "standard_version": "1.0",
  "ecosystem": {
    "total_animals": 2000,
    "region_count": 16,
    "duration_seconds": 300,
    "tick_seconds": 5,
    "max_food": 420.0,
    "food_regen_per_tick": 72.0,
    "max_region_population": 220,
    "migration_rate": 0.035,
    "mutation_rate": 0.05,
    "tick_delay_ms": 1000,
    "seed": 517498978,
    "local_top_k": 20
  },
