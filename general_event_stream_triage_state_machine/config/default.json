{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_event_stream_triage_state_machine",
    "name": "Event Stream Triage State Machine"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "seed": 42,
      "steps": 5,
      "stream_name": "synthetic_ops_events"
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Event stream triage agent",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "summarize event bursts",
      "prioritize anomalies",
      "choose routing actions"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Security operations, payments monitoring, reliability engineering, fraud detection.",
    "problem_solved": "Event streams are noisy and bursty; teams need agents that maintain state and route actions as conditions change.",
    "target_users": "Developers building alerting, stream processing, and incident triage agents."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Event stream report with queue state, triage actions, and ranked partitions.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "escalate_anomalies",
      "tighten_filter",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "event_rate",
      "anomaly_score",
      "queue_depth",
      "false_positive_rate"
    ],
    "objective": "minimize",
    "primary_metric": "queue_depth",
    "risk_metric": "anomaly_score",
    "seed_field": "seed",
    "type": "Stateful event stream simulation."
  },
  "standard_version": "1.0"
}
