  "name": "User Activity RMF Triage Assistant",
  "outputs": {
    "evidence_report": "outputs/evidence_report.json",
    "incident_summary": "outputs/incident_summary.md",
    "security_decision": "outputs/security_decision.json"
  },
  "requirements": {
    "cpu": {
      "min_cores": 1
    },
    "disk": {
      "min_gb": 1
    },
    "gpu": {
      "min_count": 0
    },
    "memory": {
      "min_gb": 2
    }
  },
  "runtime": {
    "bindings": {
      "load_inputs": {
        "risk": "low",
        "side_effect": "read",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "input_adapter",
            "model": "ollama/nemotron3:33b",
            "role": "Resolve mock, JSON, file, or env_json inputs",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      },
      "run_workflow": {
        "risk": "medium",
        "seed_inputs": {
          "config": "config.example.json",
          "events": "inputs/sample_events_high_risk.jsonl",
          "mode": "dry_run"
        },
        "side_effect": "internal_write",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "rmf_triage_analyst",
            "kind": "generic",
            "model": "ollama/nemotron3:33b",
            "role": "root_coordinator",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      },
      "write_final_artifact": {
        "risk": "low",
        "side_effect": "internal_write",
        "strategy": "single",
        "type": "worker",
        "workers": [
          {
            "id": "artifact_writer",
            "model": "ollama/nemotron3:33b",
            "role": "Write result and final artifact to the local run store",
            "uses": "mn-agents.data_python_executor@1"
          }
        ]
      }
    },
    "memory": {},
    "models": {
      "primary": {
        "model": "ollama/nemotron3:33b",
        "provider": "ollama",
        "role": "Blueprint reasoning model",
        "type": "llm"
      }
    },
    "observability": {
      "panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
        "token_budget",
        "llm_retries"
      ],
      "reads": [
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json",
        "web_ui.json"
      ],
      "schema_version": "mn.blueprint.observability_dashboard.v1",
      "source": "local_run_store"
    },
    "resources": {
      "cpu": {
        "min_cores": 1
      },
      "disk": {
        "min_gb": 1
      },
      "gpu": {
        "min_count": 0
      },
      "memory": {
        "min_gb": 2
      }
    },
    "store": {
      "artifacts": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "human.jsonl",
        "logs.jsonl",
        "resources.jsonl",
        "result.json",
        "final_artifact.json"
      ],
      "path": "./runs/${run_id}",
      "type": "local_run_store"
    },
    "worker_defaults": {
      "pool": "default",
      "pool_slots": 1,
      "runner": "MirrorNeuron.Runner.HostLocal",
      "uses": "mn-agents.data_python_executor@1",
      "workdir": "/sandbox/job/workflow"
    }
  },
  "tags": [
    "security",
    "user-activity-monitoring",
    "continuous-monitoring",
    "rmf",
    "ato",
    "cato",
    "incident-response",
    "dry-run"
  ],
  "term": "TERM.md",
  "version": 1,
  "workflow": {
    "dynamic": {
      "apply_at": "between_steps",
      "enabled": false,
      "patch_events": []
    },
    "edges": [
      {
        "accepts": [
          "done"
        ],
        "event": "inputs_loaded",
        "from": "load_inputs",
        "id": "load_inputs_to_run_workflow",
        "required": true,
        "to": "run_workflow"
      },
      {
        "accepts": [
          "done"
        ],
        "event": "workflow_result_ready",
        "from": "run_workflow",
        "id": "run_workflow_to_write_final_artifact",
        "required": true,
        "to": "write_final_artifact"
      }
    ],
    "entrypoint": "load_inputs",
    "execution": {
      "strategy": "serial"
    },
    "mode": "static_dag",
    "observers": [],
    "policy": {
      "failure": {
        "default": "fail_closed"
      },
      "human": {
        "decisions": [
          "approve",
          "revise",
          "reject"
        ],
        "default": "reject",
        "enabled": true,
        "events": {
          "decision": "human_decision_applied",
          "request": "human_input_requested",
          "response": "human_input_received",
          "timeout": "human_input_timeout"
        },
        "mode": "approval_required",
        "timeout_seconds": 3600
      },
      "safety": {
        "blocked_actions": [
          "disable_account",
          "isolate_host",
          "change_access_policy",
          "escalate_to_enforcement"
        ],
        "default": "allow",
        "rules": []
      }
    },
    "schema": "mn.workflow.problem_graph/v1",
    "sink": "write_final_artifact",
    "source": "load_inputs",
    "state": {
      "final_artifact": {},
      "resolved_inputs": {},
      "workflow_result": {}
    },
    "steps": [
      {
        "action": "load_inputs",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "inputs_loaded",
        "goal": "Resolve the selected input adapter and record input provenance.",
        "id": "load_inputs",
        "in": {},
        "kind": "stage",
        "label": "Load Inputs",
        "on": {
          "inputs_loaded": "run_workflow"
        },
        "out": {
          "resolved_inputs": "$state.resolved_inputs"
        },
        "run": "load_inputs"
      },
      {
        "action": "run_blueprint_workflow",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": null,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "workflow_result_ready",
        "goal": "User activity streams need stateful triage, safe response instructions, and audit-ready evidence tied to source events.",
        "id": "run_workflow",
        "in": {
          "inputs": "$state.resolved_inputs"
        },
        "kind": "stage",
        "label": "Run Workflow",
        "on": {
          "workflow_result_ready": "write_final_artifact"
        },
        "out": {
          "workflow_result": "$state.workflow_result"
        },
        "run": "run_workflow"
      },
      {
        "action": "write_final_artifact",
        "control": {
          "failure_policy": "fail_workflow",
          "required": true,
          "retry": {
            "backoff_multiplier": 2,
            "backoff_seconds": 1,
            "jitter": 0,
            "max_attempts": 2
          },
          "timeout_seconds": 120,
          "uncertainty": {
            "min_confidence": 0.0,
            "on_low_confidence": "continue_with_warning"
          }
        },
        "emits": "final_artifact_written",
        "goal": "Persist result.json, final_artifact.json, events, logs, and optional output-skill fan-out records.",
        "id": "write_final_artifact",
        "in": {
          "workflow_result": "$state.workflow_result"
        },
        "kind": "stage",
        "label": "Write Final Artifact",
        "on": {
          "final_artifact_written": "completed"
        },
        "out": {
          "final_artifact": "$state.final_artifact"
        },
        "run": "write_final_artifact"
      }
    ],
    "workflow_id": "user_activity_rmf_triage_assistant_v1"
  }
}
