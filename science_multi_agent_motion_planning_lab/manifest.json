{
  "description": "Visualize shared-world multi-agent motion planning and coordination behavior.",
  "edges": [
    {
      "edge_id": "ingress_to_world",
      "from_node": "ingress",
      "message_type": "simulation_start",
      "to_node": "shared_world"
    },
    {
      "edge_id": "world_to_collector",
      "from_node": "shared_world",
      "message_type": "shared_world_result",
      "to_node": "collector"
    },
    {
      "edge_id": "collector_to_visualizer",
      "from_node": "collector",
      "message_type": "shared_world_collection",
      "to_node": "visualizer"
    }
  ],
  "entrypoints": [
    "ingress"
  ],
  "graph_id": "science_multi_agent_motion_planning_lab_v1",
  "init_config_review": {
    "fields": [
      {
        "default": 25,
        "description": "Number of cooperative agents.",
        "label": "Good agents",
        "path": "motion.good_agents"
      },
      {
        "default": 75,
        "description": "Number of adversarial agents.",
        "label": "Adversaries",
        "path": "motion.adversaries"
      },
      {
        "default": 8,
        "description": "Number of obstacles in the world.",
        "label": "Obstacles",
        "path": "motion.obstacles"
      },
      {
        "default": 60,
        "description": "Simulation cycle count.",
        "label": "Max cycles",
        "path": "motion.max_cycles"
      },
      {
        "default": 4200,
        "description": "Deterministic seed for repeatable runs.",
        "label": "Simulation seed",
        "path": "motion.seed"
      },
      {
        "default": "swarm",
        "description": "Agent policy: swarm or random.",
        "label": "Policy mode",
        "path": "motion.policy_mode"
      }
    ],
    "instruction": "Review shared-world simulation settings before launching the motion planning lab.",
    "required": false
  },
  "initial_inputs": {
    "ingress": [
      {
        "adversaries": 75,
        "description": "Run one shared MPE world with many coexisting agents that collide, chase, flee, and crowd around obstacles.",
        "good_agents": 25,
        "max_cycles": 60,
        "obstacles": 8,
        "policy_mode": "swarm",
        "scenario": "pettingzoo_simple_tag_shared_world",
        "seed": 4200,
        "total_agents": 100
      }
    ]
  },
  "job_name": "science-multi-agent-motion-planning-lab",
  "manifest_version": "1.0",
  "metadata": {
    "agent_templates": {
      "library": "../mn-agents/index.json",
      "nodes": [
        {
          "node_id": "ingress",
          "uses": "mn-agents.control_router@1.0.0"
        },
        {
          "node_id": "collector",
          "uses": "mn-agents.control_join@1.0.0"
        },
        {
          "node_id": "visualizer",
          "uses": "mn-agents.data_python_executor@1.0.0"
        },
        {
          "node_id": "shared_world",
          "uses": "mn-agents.data_python_executor@1.0.0"
        }
      ],
      "render_tool": "../mn-agents/tools/render_agent_templates.py",
      "rendered_output": "manifest.rendered.json or runtime metadata",
      "renderer": "mn_blueprint_support.render_manifest_agent_templates"
    },
    "blueprint_id": "science_multi_agent_motion_planning_lab",
    "category": "science",
    "configuration_contract": {
      "optional_files": [
