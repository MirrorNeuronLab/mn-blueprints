{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "finance_zip_code_property_alpha_engine",
    "name": "Zip Code Property Alpha Engine"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "max_price": 900000,
      "seed": 42,
      "steps": 5,
      "target_zip": "02139"
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Real estate investment analyst",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "observe listing dynamics",
      "rank opportunities",
      "explain bid or watch decisions"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "finance",
    "customizable_for": "Rental acquisitions, flipping pipelines, multifamily sourcing, market expansion.",
    "problem_solved": "Property opportunities change with rates, inventory, rents, neighborhood demand, and liquidity; static comps cannot rank next-best actions.",
    "target_users": "Real-estate investors, acquisition analysts, and property-tech teams."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Ranked opportunities and bid/watchlist recommendation.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "submit_bid",
      "negotiate_discount",
      "watchlist_only"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "median_price_index",
      "demand_index",
      "cap_rate_pct",
      "risk_score"
    ],
    "objective": "maximize",
    "primary_metric": "cap_rate_pct",
    "risk_metric": "risk_score",
    "seed_field": "seed",
    "type": "ZIP-code property market simulation."
  },
  "standard_version": "1.0"
}
