      ]
    },
    "input_adapters": {
      "default": "mock",
      "resolved_artifact": "inputs.json",
      "supported": [
        "mock",
        "json",
        "file",
        "env_json"
      ]
    },
    "inputs": {
      "alert_policy": {
        "description": "Operator notification and approval policy.",
        "example": null,
        "privacy": "internal",
        "required": true,
        "type": "domain_value"
      },
      "network_events": {
        "description": "Network flow, DNS, auth, endpoint, or alert events.",
        "example": null,
        "privacy": "internal",
        "required": true,
        "type": "domain_value"
      },
      "risk_thresholds": {
        "description": "Score cutoffs for low, medium, high, and critical findings.",
        "example": null,
        "privacy": "internal",
        "required": true,
        "type": "domain_value"
      }
    },
    "outputs": {
      "artifacts": [
        {
          "artifact_id": "run_metadata",
          "mime_type": "application/json",
          "path": "run.json",
          "producer": "local_run_store",
          "schema_version": "mn.artifact.run_summary.v1",
          "source_refs": [],
          "type": "run_summary"
        },
        {
          "artifact_id": "resolved_config",
          "mime_type": "application/json",
          "path": "config.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.config.v1",
          "source_refs": [],
          "type": "config"
        },
        {
          "artifact_id": "resolved_inputs",
          "mime_type": "application/json",
          "path": "inputs.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.inputs.v1",
          "source_refs": [],
          "type": "inputs"
        },
        {
          "artifact_id": "event_stream",
          "mime_type": "application/x-jsonlines",
          "path": "events.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.events.v1",
          "source_refs": [],
          "type": "events"
        },
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "path": "result.json",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.response.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl"
          ],
          "type": "result"
        },
        {
          "artifact_id": "final_artifact",
          "mime_type": "application/json",
          "path": "final_artifact.json",
          "producer": "workflow",
          "schema_version": "mn.blueprint.final_artifact.v1",
          "source_refs": [
            "inputs.json",
            "events.jsonl",
            "result.json"
          ],
          "type": "final_artifact"
        },
        {
          "artifact_id": "logs",
          "mime_type": "application/x-jsonlines",
          "path": "logs.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.logs.v1",
          "source_refs": [
            "events.jsonl"
          ],
          "type": "logs"
        },
        {
          "artifact_id": "resources",
          "mime_type": "application/x-jsonlines",
          "path": "resources.jsonl",
          "producer": "local_run_store",
          "schema_version": "mn.blueprint.resources.v1",
