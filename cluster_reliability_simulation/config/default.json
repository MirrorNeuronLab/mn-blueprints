{
  "agent_handoffs": {},
  "backpressure": {
    "drop_policy": "skip_with_error",
    "llm": {
      "max_calls_per_minute": 30,
      "max_concurrent_calls": 2
    },
    "max_concurrency": 6,
    "max_events_per_second": 25,
    "queue_size": 1000
  },
  "budgets": {
    "max_connector_reads": 500,
    "max_connector_writes": 20,
    "max_disk_mb": 250,
    "max_llm_calls": 20,
    "max_llm_tokens": 20000,
    "max_runtime_seconds": 900,
    "max_stream_duration_seconds": 3600
  },
  "capabilities": {
    "optional": [
      "llm.call",
      "network.egress",
      "service.check",
      "cluster.drain",
      "cluster.maintenance"
    ],
    "required": [
      "filesystem.write",
      "cluster.inspect",
      "cluster.schedule"
    ]
  },
  "cluster_reliability": {
    "demo_variants": {
      "batch": {
        "job_type": "batch",
        "reschedule_attempts": 1,
        "restart_mode": "fail"
      },
      "service": {
        "job_type": "service",
        "reschedule_unlimited": true,
        "restart_mode": "fail"
      },
      "sysbatch": {
        "completes_once_per_node": true,
        "expands_per_node": true,
        "job_type": "sysbatch"
      },
      "system": {
        "expands_per_node": true,
        "ignored_by_default_drain": true,
        "job_type": "system"
      }
    },
    "local_node_hint": "mn1@local",
    "nomad_inspired_features": [
      "service jobs",
      "batch jobs",
      "system jobs",
      "sysbatch jobs",
      "spread scheduling",
      "binpack scheduling",
      "resource placement",
      "capability constraints",
      "restart policies",
      "reschedule policies",
      "maintenance mode",
      "drain mode",
      "service registry",
      "health checks",
      "leader sweeps",
      "recovery eval retries"
    ],
    "operator_runbook": [
      "verify both nodes are visible and schedulable",
      "submit or dry-run the service blueprint",
      "inspect scheduler placements and reliability metadata",
      "run a drain dry-run on the remote node",
      "toggle maintenance mode and confirm new placements avoid that node",
      "cancel drain or mark eligible after the rehearsal"
    ],
    "remote_node_hint": "mn2@192.168.4.173",
    "scheduler_checks": [
      {
        "expected_min_nodes": 2,
        "job_type": "service",
        "name": "spread_service_plan",
        "strategy": "spread"
      },
      {
        "expected_min_nodes": 1,
        "job_type": "batch",
        "name": "binpack_batch_plan",
        "strategy": "binpack"
      },
      {
        "expected_source_agent_preserved": true,
        "job_type": "system",
        "name": "system_expansion_plan",
        "strategy": "spread"
      },
      {
        "expected_completion": "one copy per eligible node",
        "job_type": "sysbatch",
        "name": "sysbatch_expansion_plan",
        "strategy": "spread"
      }
    ],
    "schema_version": "mn.cluster_reliability.demo.v1"
  },
  "determinism": {
    "enabled": true,
    "frozen_clock": null,
    "replay": {
      "from_events": "events.jsonl",
      "from_inputs": "inputs.json",
      "llm_mode": "mock"
    },
    "seed_field": "seed"
  },
  "error_handling": {
    "default_mode": "stop",
    "policies": {
      "llm_call": {
        "backoff_seconds": 2,
        "max_attempts": 3,
        "mode": "retry"
      },
      "optional_output": {
        "mode": "skip"
      },
      "required_output": {
        "mode": "stop"
      }
    }
  },
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "evaluate_workflow_state",
    "route_by_context",
    "request_human_input",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact",
    "fan_out_output_skills"
  ],
  "human_control": {
    "enabled": false,
    "events": [
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied"
    ],
    "mode": "disabled",
    "reason": "This blueprint is a low-risk runtime or simulation pattern that only writes local decision-support artifacts."
  },
  "identity": {
    "blueprint_id": "cluster_reliability_simulation",
    "name": "Cluster Reliability Simulation"
  },
  "input_skills": {},
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "drain_deadline_ms": 30000,
      "local_node_hint": "mn1@local",
      "remote_node_hint": "mn2@192.168.4.173",
      "scenario": "two_box_combined_cluster"
