{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_dynamic_environment_control_loop",
    "name": "Dynamic Environment Control Loop"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "seed": 42,
      "steps": 5,
      "weather_pattern": "afternoon peak"
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "Dynamic environment controller",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "watch exogenous changes",
      "choose a control action",
      "preserve service level"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Energy systems, cloud capacity, industrial operations, logistics control rooms.",
    "problem_solved": "Operational systems are coupled and time-varying; one-shot advice cannot show how a control action changes the next state.",
    "target_users": "Developers and operators testing control-loop blueprints before adding domain data."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Control summary with metric trajectory and recommended action.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "charge_battery",
      "shed_noncritical_load",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "load",
      "temperature",
      "battery_reserve",
      "service_level"
    ],
    "objective": "maximize",
    "primary_metric": "service_level",
    "risk_metric": "load",
    "seed_field": "seed",
    "type": "Closed-loop control simulation."
  },
  "standard_version": "1.0"
}
