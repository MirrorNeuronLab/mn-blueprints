      "env": "MN_BLUEPRINT_QUICK_TEST=1"
    },
    "runtime_features": [
      "OpenShell isolation",
      "executor routing",
      "aggregator completion",
      "policy-controlled execution"
    ],
    "simulation_type": "Static worker pipeline with deterministic generated input.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "status_logging": {
      "env": "MN_BLUEPRINT_LOG_LEVEL",
      "format": "jsonl",
      "stream": "stderr"
    },
    "target_user": "Developers evaluating sandboxed worker execution and artifact handoff patterns."
  },
  "name": "Openshell Sandbox Worker Pipeline",
  "nodes": [
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "bash",
          "scripts/collect_metrics.sh"
        ],
        "from": "base",
        "name_prefix": "shell-worker",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "shell_metrics",
        "policy": "policies/api-egress.yaml",
        "pool": "default",
        "pool_slots": 1,
        "tty": false,
        "upload_as": "word_count",
        "upload_path": "word_count",
        "workdir": "/sandbox/job/word_count"
      },
      "node_id": "shell_worker",
      "role": "root_coordinator",
      "type": "generic",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "command": [
          "bash",
          "scripts/collect_metrics.sh"
        ],
        "name_prefix": "shell-worker",
        "node_type": "generic",
        "output_message_type": "shell_metrics",
        "policy": "policies/api-egress.yaml",
        "role": "root_coordinator",
        "script": "scripts/run_blueprint.py",
        "upload_path": "word_count"
      }
    },
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/build_report.py"
        ],
        "from": "base",
        "name_prefix": "python-worker",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "python_report",
        "policy": "policies/api-egress.yaml",
        "pool": "default",
        "pool_slots": 1,
        "tty": false,
        "upload_as": "report",
        "upload_path": "report",
        "workdir": "/sandbox/job/report"
      },
      "node_id": "python_worker",
      "type": "generic",
      "uses": "mn-agents.data_python_executor@1.0.0",
      "with": {
        "name_prefix": "python-worker",
        "node_type": "generic",
        "output_message_type": "python_report",
        "policy": "policies/api-egress.yaml",
        "script": "scripts/build_report.py",
        "upload_path": "report"
      }
    },
    {
      "agent_type": "aggregator",
      "config": {
        "complete_on_message": true
      },
      "node_id": "result_sink",
      "type": "reduce",
      "uses": "mn-agents.control_join@1.0.0",
      "with": {
        "complete_on_message": true,
        "node_type": "reduce"
      }
    }
  ],
  "policies": {
    "recovery_mode": "cluster_recover"
  },
  "requiredContextEngine": false
}
