    },
    "problem_solved": "Most LLM demos stop after one answer; real operations require repeated observations, decisions, state updates, and traceable outcomes.",
    "quick_test": {
      "command": "python3 payloads/simulation_loop/scripts/run_blueprint.py --mock-llm --steps 2",
      "enabled": true
    },
    "runtime_features": [
      "closed-loop agent",
      "dynamic state",
      "decision feedback",
      "structured final artifact"
    ],
    "simulation": {
      "actions": [
        "increase_capacity",
        "focus_quality",
        "hold_policy"
      ],
      "agent_role": "Operations loop controller",
      "dynamic_metrics": [
        "backlog",
        "capacity",
        "quality_score",
        "operating_cost"
      ]
    },
    "simulation_type": "Time-stepped operations queue simulation.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
