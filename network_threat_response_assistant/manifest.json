            "blueprint",
            "network_threat_response_assistant",
            "gradio"
          ]
        },
        "writes": "ui.json and web_ui.json"
      },
      "server": "blueprint_support",
      "standard_panels": [
        "current_status",
        "recent_events",
        "pending_human_requests",
        "output_artifacts",
        "resource_usage",
        "errors",
        "llm_calls",
