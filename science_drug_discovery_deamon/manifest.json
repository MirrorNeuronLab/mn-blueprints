        "workdir": "/sandbox/job/worker",
        "pool": "default",
        "pool_slots": 1,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "command": ["python3", "scripts/stage_b.py"],
        "output_message_type": "structures_ready"
      }
    },
    {
