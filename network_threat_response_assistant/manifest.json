      }
    ],
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load_metadata -> resolve_config -> load_inputs -> start_run_store -> observe_simulation_state -> call_llm_agent -> evaluate_workflow_state -> route_by_context -> request_human_input -> apply_decision_to_simulation -> emit_events -> write_final_artifact -> fan_out_output_skills",
      "execution_steps": [
        "load_metadata",
        "resolve_config",
        "load_inputs",
        "start_run_store",
        "observe_simulation_state",
        "call_llm_agent",
        "evaluate_workflow_state",
        "route_by_context",
        "request_human_input",
        "apply_decision_to_simulation",
        "emit_events",
        "write_final_artifact",
        "fan_out_output_skills"
      ],
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0",
      "workflow_api_version": "mn.workflow/v1",
      "workflow_model": "contract -> workflow -> agents/runtime"
    },
    "standard_version": "1.0",
    "status_contract": {
      "heartbeat_event": "blueprint_status",
      "heartbeat_required": true,
      "phases": [
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "loading_inputs",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "running_worker",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "waiting_for_human",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "writing_artifacts",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        },
        {
          "completion_event": "blueprint_phase_completed",
          "failure_event": "blueprint_phase_failed",
          "phase": "completed",
          "progress_event": "blueprint_status",
          "required": true,
          "start_event": "blueprint_phase_started"
        }
      ],
      "schema_version": "mn.blueprint.status_contract.v1",
      "source": "run_store",
      "status_event": "blueprint_status"
