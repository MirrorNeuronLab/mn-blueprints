  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed",
      "blueprint_status",
      "blueprint_phase_started",
      "blueprint_phase_completed",
      "blueprint_phase_failed",
      "artifact_written",
      "human_notice",
      "human_input_requested",
      "human_input_received",
      "human_input_timeout",
      "human_decision_applied",
      "output_skill_started",
      "output_skill_completed",
      "output_skill_failed",
      "agent_beacon",
      "actor_activity",
      "workflow_graph_compiled",
      "workflow_finished"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "logs_jsonl": true,
    "redact_env_secrets": true,
    "redact_fields": [
      "api_key",
      "token",
      "authorization",
      "cookie",
      "password",
      "private_key"
    ],
    "rotation": {
      "check_interval_records": 100,
      "compress": "background",
      "enabled": true,
      "max_bytes_mb": 100,
      "max_segments": 7,
      "span_seconds": 86400
    },
    "stderr_jsonl": true,
    "writer": {
      "batch_size": 100,
      "flush_interval_seconds": 0.5,
      "mode": "async",
      "overflow_policy": "drop_low_priority",
      "queue_size": 10000,
      "shutdown_flush_timeout_seconds": 2
    }
  },
  "memory_layer": {
    "collection": "mn_memory",
    "containers": "optional_sidecar",
    "context_addr_env": "MN_CONTEXT_ADDR",
    "conversation": {
      "agent_role": "otterdesk_chat",
      "include_human_events": true,
      "include_runtime_events": true,
      "include_runtime_logs": true,
      "target_tokens": 2400,
      "token_budget": 6000,
      "use_model_compression": false
    },
    "conversation_enabled": true,
    "conversation_enabled_env": "OTTERDESK_CONTEXT_MEMORY_ENABLED",
    "default_context_addr": "localhost:50052",
    "enabled": true,
    "enabled_env": "MN_CONTEXT_MEMORY_ENABLED",
    "namespace": "codebase_context_memory_analysis_assistant_context",
    "project_path": "${MN_MEMBRANE_PROJECT_PATH}",
    "python_sdk_path": "${MN_MEMBRANE_SDK_PATH}",
    "sdk_distribution": "mirrorneuron-membrane-python-sdk",
    "sdk_import_package": "mn_context_engine_sdk"
  },
  "metadata": {
    "blueprint_id": "codebase_context_memory_analysis_assistant",
    "blueprint_revision": "v1",
    "category": "business",
    "customizable_for": "Architecture review, codebase onboarding, migration planning, technical due diligence, and large-repo code review.",
    "name": "Codebase Context Memory Analysis Assistant",
    "problem_solved": "Large codebases produce more facts than an LLM can safely carry; Membrane working memory must preserve source refs, subsystem boundaries, pinned repo facts, and private review notes under tight context budgets.",
    "standard_version": "1.0",
    "target_users": "Engineering leaders and platform teams evaluating memory systems for code analysis agents."
  },
  "mode": "mock",
  "output_skills": {},
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "Compressed code-analysis handoff, final architecture briefing, and context-memory benchmark report.",
    "run_root": "~/.mn/runs",
    "skills": {},
    "tcp": {
      "enabled": false,
      "ports": []
    },
    "write_run_store": true
  },
  "privacy": {
    "default_classification": "internal",
    "rules": {
      "confidential": {
        "log": "redacted",
        "send_to_llm": "allowed_configs_only",
        "send_to_output_skills": "approved_destinations_only"
      },
      "internal": {
        "log": "metadata_only",
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "public": {
        "log": true,
        "send_to_llm": true,
        "send_to_output_skills": true
      },
      "regulated": {
        "log": "redacted",
        "send_to_llm": false,
        "send_to_output_skills": "approved_destinations_only"
      }
    }
  },
  "real_adapters": {
    "github_tree_fixture": {
      "adapter": "file",
      "description": "Replace payloads/repo_fixture/django_tree_fixture.json with a tree fixture generated from another repository.",
      "path": "payloads/repo_fixture/django_tree_fixture.json"
    },
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "resources": {
    "enabled": true,
    "gpu_enabled": "auto",
