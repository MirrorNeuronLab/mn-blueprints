{
  "daemon": false,
  "description": "Optimize disruption responses before inventory, supplier delays, and customer service levels break down.",
  "edges": [
    {
      "edge_id": "simulation_to_report",
      "from_node": "simulation_loop",
      "message_type": "blueprint_report",
      "to_node": "report_sink"
    }
  ],
  "entrypoints": [
    "simulation_loop"
  ],
  "graph_id": "business_supply_chain_resilience_war_room_v1",
  "initial_inputs": {
    "simulation_loop": [
      {
        "daily_demand_units": 650,
        "optimization_budget_usd": 65000,
        "product": "industrial sensor",
        "region": "Northeast",
        "seed": 42,
        "target_inventory_days": 22,
        "steps": 5
      }
    ]
  },
  "job_name": "business-supply-chain-resilience-war-room",
  "manifest_version": "1.0",
  "metadata": {
    "blueprint_id": "business_supply_chain_resilience_war_room",
    "category": "business",
    "customizable_for": "Manufacturing, retail, healthcare supplies, logistics networks.",
    "description": "Optimize disruption responses before inventory, supplier delays, and customer service levels break down.",
    "interfaces": {
      "config": [
        "metadata",
        "identity",
        "inputs",
        "simulation",
        "llm",
        "outputs",
        "logging",
        "real_adapters"
      ],
      "identity": [
        "blueprint_id",
        "name",
        "run_id"
      ],
      "input_adapters": [
        "mock",
        "json",
        "file",
        "env_json"
      ],
      "output_adapters": [
        "local_run_store"
      ],
      "outputs": [
        "run.json",
        "config.json",
        "inputs.json",
        "events.jsonl",
        "result.json",
        "final_artifact.json"
      ]
    },
    "llm": {
      "default_api_base": "http://192.168.4.173:11434",
      "default_model": "ollama/nemotron3:33b",
      "mock_mode": "run payloads/simulation_loop/scripts/run_blueprint.py --mock-llm"
    },
    "llm_agent_role": "Supply chain disruption response agent.",
    "name": "Supply Chain Resilience War Room",
    "optimization": {
      "fallback": "deterministic fractional LP allocator when Pyomo or a solver is not installed",
      "language": "Pyomo",
      "model_type": "linear_program",
      "objective": "minimize mitigation cost plus unmet resilience-gap penalty subject to budget and lane capacity",
      "solver": "appsi_highs"
    },
    "output": "Disruption response plan with optimized mitigation quantities, action history, and supplier-lane ranking.",
    "output_contract": {
      "events": "blueprint_report",
      "stdout": "JSON object with timeline, state_changes, final_artifact, and llm metadata"
    },
    "problem_solved": "Demand spikes and supplier delays compound over time; static dashboards show the fire but do not optimize budget-constrained mitigation paths.",
    "quick_test": {
      "command": "python3 payloads/simulation_loop/scripts/run_blueprint.py --mock-llm --steps 2",
      "enabled": true
    },
    "runtime_features": [
      "dynamic simulation",
      "Pyomo optimization model",
      "LLM planner",
      "time-varying inventory",
      "decision loop"
    ],
    "simulation": {
      "actions": [
        "expedite_freight",
        "switch_supplier",
        "allocate_inventory"
      ],
      "agent_role": "Supply chain disruption response agent",
      "dynamic_metrics": [
        "inventory_days",
        "demand_index",
        "supplier_delay_days",
        "service_level"
      ],
      "optimization_model": "Pyomo linear program for budget-constrained disruption mitigation"
    },
    "simulation_type": "Inventory, demand, supplier-delay, and Pyomo optimization simulation.",
    "standard": {
      "config_path": "config/default.json",
      "default_input_adapter": "mock",
      "execution_model": "load metadata -> resolve config -> load inputs -> simulate/decide loop -> emit events -> write final artifact",
      "output_adapter": "local_run_store",
      "real_input_adapters": [
        "file",
        "json",
        "env_json"
      ],
      "run_store": "~/.mn/runs/<run_id>/",
      "version": "1.0"
    },
    "target_user": "Supply chain operators, procurement leaders, and operations executives."
  },
  "name": "Supply Chain Resilience War Room",
  "nodes": [
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/run_blueprint.py"
        ],
        "environment": {
          "LITELLM_API_BASE": "http://192.168.4.173:11434",
          "LITELLM_MAX_TOKENS": "700",
          "LITELLM_MODEL": "ollama/nemotron3:33b",
          "LITELLM_NUM_RETRIES": "1",
          "LITELLM_TIMEOUT_SECONDS": "60",
          "MN_BLUEPRINT_ID": "business_supply_chain_resilience_war_room",
          "MN_LLM_API_BASE": "http://192.168.4.173:11434",
          "MN_LLM_MAX_TOKENS": "700",
          "MN_LLM_MODEL": "ollama/nemotron3:33b",
          "MN_LLM_NUM_RETRIES": "1",
          "MN_LLM_TIMEOUT_SECONDS": "60"
        },
        "from": "base",
        "name_prefix": "business_supply_chain_disruption",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "blueprint_report",
        "pool": "default",
        "pool_slots": 1,
        "tty": false,
        "upload_as": "simulation_loop",
        "upload_path": "simulation_loop",
        "workdir": "/sandbox/job/simulation_loop"
      },
      "node_id": "simulation_loop",
      "role": "root_coordinator",
      "type": "generic"
    },
    {
      "agent_type": "aggregator",
      "config": {
        "complete_on_message": true
      },
      "node_id": "report_sink",
      "role": "result_sink",
      "type": "reduce"
    }
  ],
  "policies": {
    "recovery_mode": "local_restart"
  },
  "requiredContextEngine": false
}
