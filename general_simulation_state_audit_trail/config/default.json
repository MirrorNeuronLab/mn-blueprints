{
  "execution_model": [
    "load_metadata",
    "resolve_config",
    "load_inputs",
    "start_run_store",
    "observe_simulation_state",
    "call_llm_agent",
    "apply_decision_to_simulation",
    "emit_events",
    "write_final_artifact"
  ],
  "identity": {
    "blueprint_id": "general_simulation_state_audit_trail",
    "name": "Simulation State Audit Trail"
  },
  "inputs": {
    "adapter": "mock",
    "description": "Default synthetic inputs bundled with the blueprint.",
    "payload": {
      "checkpoint_every_steps": 2,
      "seed": 42,
      "steps": 5
    }
  },
  "interfaces": {
    "config_sections": [
      "metadata",
      "identity",
      "inputs",
      "simulation",
      "llm",
      "outputs",
      "logging",
      "real_adapters"
    ],
    "identity_fields": [
      "blueprint_id",
      "name",
      "run_id"
    ],
    "input_adapters": [
      "mock",
      "json",
      "file",
      "env_json"
    ],
    "output_adapters": [
      "local_run_store"
    ],
    "run_artifacts": [
      "run.json",
      "config.json",
      "inputs.json",
      "events.jsonl",
      "result.json",
      "final_artifact.json"
    ]
  },
  "llm": {
    "agent_role": "State tracking analyst",
    "api_base": "http://192.168.4.173:11434",
    "mock_mode": "fake",
    "mode": "ollama",
    "model": "ollama/nemotron3:33b",
    "responsibilities": [
      "compare current and prior state",
      "detect material changes",
      "choose a stabilizing action"
    ]
  },
  "logging": {
    "events": [
      "run_started",
      "inputs_loaded",
      "simulation_step_started",
      "llm_decision",
      "simulation_state_updated",
      "run_completed"
    ],
    "events_jsonl": true,
    "level": "INFO",
    "redact_env_secrets": true
  },
  "metadata": {
    "category": "general",
    "customizable_for": "Regulated operations, simulations, workflow audits, model evaluations.",
    "problem_solved": "Dynamic systems are hard to trust unless users can see what changed, why an action was chosen, and how the next state moved.",
    "target_users": "Developers and evaluators who need inspectable state transitions."
  },
  "mode": "mock",
  "outputs": {
    "adapter": "local_run_store",
    "artifact_contract": "State tracking report with deltas and ranked subsystems.",
    "run_root": "~/.mn/runs",
    "write_run_store": true
  },
  "real_adapters": {
    "inline_json": {
      "adapter": "json",
      "description": "Load overrides from an inline JSON object.",
      "payload": {}
    },
    "input_file": {
      "adapter": "file",
      "description": "Load JSON overrides from a local file path.",
      "path": null
    }
  },
  "simulation": {
    "actions": [
      "checkpoint_state",
      "stabilize_system",
      "hold_policy"
    ],
    "deterministic": true,
    "enabled": true,
    "metrics": [
      "state_drift",
      "measurement_confidence",
      "intervention_count",
      "stability_score"
    ],
    "objective": "maximize",
    "primary_metric": "stability_score",
    "risk_metric": "state_drift",
    "seed_field": "seed",
    "type": "State tracking and checkpoint simulation."
  },
  "standard_version": "1.0"
}
