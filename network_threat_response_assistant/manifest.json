          "lifecycle": "runtime_managed",
          "meta": {
            "adapter": "gradio",
            "blueprint_id": "network_threat_response_assistant",
            "run_id": "${run_id}"
          },
          "provider": "mirror_neuron",
          "registered_by": "launch_prepare_web_ui",
          "service_name": "blueprint-web-ui",
          "tags": [
